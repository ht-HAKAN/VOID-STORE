                                                           FontSize="20"
                                                           FontWeight="SemiBold"
                                                           Margin="0,10,0,0"/>
                                                <TextBlock x:Name="txtDetailInstallSize"
                                                           Foreground="#9BA5B2"
                                                           FontSize="12"
                                                           Margin="0,10,0,0"/>
                                                <ProgressBar x:Name="pbDetailInstallProgress"
                                                             Style="{StaticResource DownloadProgressBar}"
                                                             Maximum="100"
                                                             Foreground="#6FCBFF"
                                                             Margin="0,14,0,0"
                                                             Visibility="Collapsed"/>
                                                <TextBlock x:Name="txtDetailInstallProgress"
                                                           Foreground="#9BA5B2"
                                                           FontSize="12"
                                                           Margin="0,10,0,0"
                                                           Visibility="Collapsed"/>
                                                <Grid Margin="0,18,0,0">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="12"/>
                                                        <ColumnDefinition Width="*"/>
                                                    </Grid.ColumnDefinitions>
                                                    <Button x:Name="btnDetailPrimaryInstallAction"
                                                            Content="Kurulumu Başlat"
                                                            Style="{StaticResource PrimaryActionButton}"
                                                            Height="48"
                                                            Click="DetailPrimaryInstallActionButton_Click"/>
                                                    <Button x:Name="btnDetailSecondaryInstallAction"
                                                            Grid.Column="2"
                                                            Content="İptal"
                                                            Style="{StaticResource GhostActionButton}"
                                                            Height="48"
                                                            Click="DetailSecondaryInstallActionButton_Click"/>
                                                </Grid>
                                                <TextBlock x:Name="txtDetailInstallPath"
                                                           Foreground="#6F7A88"
                                                           FontSize="11"
                                                           Margin="0,14,0,0"
                                                           TextWrapping="Wrap"
                                                           Visibility="Collapsed"/>
                                            </StackPanel>
                                        </Border>
                                        <Rectangle Height="1"
                                                   Fill="#171B22"
                                                   Margin="0,28,0,24"/>
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                            </Grid.RowDefinitions>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="18"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="Yapımcı"
                                                       Style="{StaticResource DetailMetaLabel}"/>
                                            <TextBlock x:Name="txtDetailDeveloper"
                                                       Grid.Column="2"
                                                       Style="{StaticResource DetailMetaValue}"/>
                                            <Rectangle Grid.Row="1"
                                                       Grid.ColumnSpan="3"
                                                       Height="1"
                                                       Fill="#171B22"
                                                       Margin="0,14,0,14"/>
                                            <TextBlock Grid.Row="2"
                                                       Text="Yayıncı"
                                                       Style="{StaticResource DetailMetaLabel}"/>
                                            <TextBlock x:Name="txtDetailPublisher"
                                                       Grid.Row="2"
                                                       Grid.Column="2"
                                                       Style="{StaticResource DetailMetaValue}"/>
                                            <Rectangle Grid.Row="3"
                                                       Grid.ColumnSpan="3"
                                                       Height="1"
                                                       Fill="#171B22"
                                                       Margin="0,14,0,14"/>
                                            <TextBlock Grid.Row="4"
                                                       Text="Çıkış Tarihi"
                                                       Style="{StaticResource DetailMetaLabel}"/>
                                            <TextBlock x:Name="txtDetailReleaseDate"
                                                       Grid.Row="4"
                                                       Grid.Column="2"
                                                       Style="{StaticResource DetailMetaValue}"/>
                                            <Rectangle Grid.Row="5"
                                                       Grid.ColumnSpan="3"
                                                       Height="1"
                                                       Fill="#171B22"
                                                       Margin="0,14,0,14"/>
                                            <TextBlock Grid.Row="6"
                                                       Text="Kategori"
                                                       Style="{StaticResource DetailMetaLabel}"/>
                                            <TextBlock x:Name="txtDetailCategoryValue"
                                                       Grid.Row="6"
                                                       Grid.Column="2"
                                                       Style="{StaticResource DetailMetaValue}"/>
                                        </Grid>
                                        <Rectangle Height="1"
                                                   Fill="#171B22"
                                                   Margin="0,28,0,24"/>
                                        <TextBlock Text="Platformlar"
                                                   Foreground="White"
                                                   FontSize="20"
                                                   FontWeight="SemiBold"/>
                                        <ItemsControl x:Name="icDetailPlatforms" Margin="0,18,0,0">
                                            <ItemsControl.ItemsPanel>
                                                <ItemsPanelTemplate>
                                                    <StackPanel/>
                                                </ItemsPanelTemplate>
                                            </ItemsControl.ItemsPanel>
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <StackPanel Orientation="Horizontal"
                                                                Margin="0,0,0,12">
                                                        <Ellipse Width="6"
                                                                 Height="6"
                                                                 Fill="#FFFFFF"
                                                                 Margin="0,7,10,0"
                                                                 VerticalAlignment="Top"/>
                                                        <TextBlock Text="{Binding}"
                                                                   Style="{StaticResource DetailBodyText}"/>
                                                    </StackPanel>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                        <Rectangle Height="1"
                                                   Fill="#171B22"
                                                   Margin="0,28,0,24"/>
                                        <TextBlock Text="Minimum Sistem Gereksinimleri"
                                                   Foreground="White"
                                                   FontSize="20"
                                                   FontWeight="SemiBold"/>
                                        <TextBlock x:Name="txtMinimumRequirements"
                                                   Style="{StaticResource DetailBodyText}"
                                                   Margin="0,18,0,0"/>
                                        <Rectangle Height="1"
                                                   Fill="#171B22"
                                                   Margin="0,28,0,24"/>
                                        <TextBlock Text="Önerilen Sistem Gereksinimleri"
                                                   Foreground="White"
                                                   FontSize="20"
                                                   FontWeight="SemiBold"/>
                                        <TextBlock x:Name="txtRecommendedRequirements"
                                                   Style="{StaticResource DetailBodyText}"
                                                   Margin="0,18,0,0"/>
                                    </StackPanel>
                                </Grid>
                            </StackPanel>
                        </ScrollViewer>
                        <ScrollViewer x:Name="InstallContentPanel" Visibility="Collapsed" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                            <Grid Margin="0,8,0,28">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="0"/>
                                    <RowDefinition Height="0"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="34"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="54"/>
                                    <ColumnDefinition Width="320"/>
                                </Grid.ColumnDefinitions>
                                <Border Grid.Row="2"
                                        Grid.ColumnSpan="3"
                                        Height="420"
                                        CornerRadius="34"
                                        ClipToBounds="True">
                                    <Grid>
                                        <Image x:Name="imgInstallHero"
                                               Stretch="UniformToFill"/>
                                        <Border Background="#24090B10"/>
                                        <Border>
                                            <Border.Background>
                                                <LinearGradientBrush StartPoint="0.5,0"
                                                                     EndPoint="0.5,1">
                                                    <GradientStop Color="#05090B10"
                                                                  Offset="0"/>
                                                    <GradientStop Color="#2A090B10"
                                                                  Offset="0.4"/>
                                                    <GradientStop Color="#D8090B10"
                                                                  Offset="1"/>
                                                </LinearGradientBrush>
                                            </Border.Background>
                                        </Border>
                                        <StackPanel VerticalAlignment="Top"
                                                    Margin="44,30,470,0">
                                            <TextBlock x:Name="txtInstallTitle"
                                                       Foreground="White"
                                                       FontSize="36"
                                                       FontWeight="Bold"
                                                       TextWrapping="Wrap"
                                                       Margin="0,0,0,0"/>
                                        </StackPanel>
                                        <StackPanel VerticalAlignment="Bottom"
                                                    HorizontalAlignment="Left"
                                                    Margin="44,0,0,36">
                                            <TextBlock x:Name="txtInstallPlaySummary"
                                                       Foreground="#DCE4EE"
                                                       FontSize="13"
                                                       FontWeight="Medium"
                                                       Margin="0,0,0,14"/>
                                            <StackPanel Orientation="Horizontal"
                                                        Margin="0,0,0,0">
                                                <Button x:Name="btnInstallPrimaryAction"
                                                        Content="YÜKLE"
                                                        Style="{StaticResource InstallHeroPrimaryActionButton}"
                                                        Width="220"
                                                        Height="58"
                                                        HorizontalAlignment="Left"
                                                        Click="DetailPrimaryInstallActionButton_Click"/>
                                                <Button x:Name="btnInstallSecondaryAction"
                                                        Content="İptal"
                                                        Style="{StaticResource InstallHeroSecondaryActionButton}"
                                                        Width="154"
                                                        Height="58"
                                                        Margin="14,0,0,0"
                                                        Click="DetailSecondaryInstallActionButton_Click"/>
                                            </StackPanel>
                                            <ProgressBar x:Name="pbInstallProgress"
                                                         Style="{StaticResource DownloadProgressBar}"
                                                         Maximum="100"
                                                         Foreground="#6FCBFF"
                                                         Margin="0,16,0,0"
                                                         Width="388"
                                                         Visibility="Collapsed"/>
                                            <TextBlock x:Name="txtInstallProgress"
                                                       Foreground="#A9B2BF"
                                                       FontSize="12"
                                                       Margin="0,10,0,0"
                                                       Visibility="Collapsed"/>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                                <StackPanel Grid.Row="4"
                                            Grid.Column="0">
                                    <TextBlock Text="Oyun Hakkında"
                                               Style="{StaticResource DetailSectionTitle}"/>
                                    <TextBlock x:Name="txtInstallDescription"
                                               Style="{StaticResource DetailBodyText}"
                                               Margin="0,18,0,0"/>
                                    <Rectangle Height="1"
                                               Fill="#171B22"
                                               Margin="0,30,0,26"/>
                                    <TextBlock Text="Desteklenen Diller"
                                               Foreground="White"
                                               FontSize="24"
                                               FontWeight="SemiBold"/>
                                    <TextBlock x:Name="txtInstallLanguagesValue"
                                               Style="{StaticResource DetailBodyText}"
                                               Margin="0,18,0,0"/>
                                </StackPanel>
                                <StackPanel Grid.Row="4"
                                            Grid.Column="2">
                                    <Border CornerRadius="26"
                                            BorderBrush="#202530"
                                            BorderThickness="1"
                                            ClipToBounds="True">
                                        <Image x:Name="imgInstallCover"
                                               Height="440"
                                               Stretch="UniformToFill"/>
                                    </Border>
                                    <Rectangle Height="1"
                                               Fill="#171B22"
                                               Margin="0,30,0,26"/>
                                    <TextBlock Text="Oyun Bilgileri"
                                               Foreground="White"
                                               FontSize="24"
                                               FontWeight="SemiBold"/>
                                    <Grid Margin="0,18,0,0">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="18"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="Satın Alma Tarihi" Style="{StaticResource DetailMetaLabel}"/>
                                        <TextBlock x:Name="txtInstallDeveloperValue" Grid.Column="2" Style="{StaticResource DetailMetaValue}"/>
                                        <Rectangle Grid.Row="1" Grid.ColumnSpan="3" Height="1" Fill="#171B22" Margin="0,14,0,14"/>
                                        <TextBlock Grid.Row="2" Text="Toplam Oynama Süresi" Style="{StaticResource DetailMetaLabel}"/>
                                        <TextBlock x:Name="txtInstallPublisherValue" Grid.Row="2" Grid.Column="2" Style="{StaticResource DetailMetaValue}"/>
                                        <Rectangle Grid.Row="3" Grid.ColumnSpan="3" Height="1" Fill="#171B22" Margin="0,14,0,14"/>
                                        <TextBlock Grid.Row="4" Text="Yayıncı" Style="{StaticResource DetailMetaLabel}"/>
                                        <TextBlock x:Name="txtInstallReleaseValue" Grid.Row="4" Grid.Column="2" Style="{StaticResource DetailMetaValue}"/>
                                        <Rectangle Grid.Row="5" Grid.ColumnSpan="3" Height="1" Fill="#171B22" Margin="0,14,0,14"/>
                                        <TextBlock Grid.Row="6" Text="Platformlar" Style="{StaticResource DetailMetaLabel}"/>
                                        <TextBlock x:Name="txtInstallPlatformsValue" Grid.Row="6" Grid.Column="2" Style="{StaticResource DetailMetaValue}" TextWrapping="Wrap"/>
                                    </Grid>
                                </StackPanel>
                            </Grid>
                        </ScrollViewer>
                    </Grid>
                </Grid>
            </Grid>
        </Grid>
    </Border>
</Window>

