<Window x:Class="VOID_STORE.Views.AdminCreateGame"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="VOID STORE ADMIN"
        Height="980"
        Width="1560"
        MinHeight="900"
        MinWidth="1360"
        WindowStyle="None"
        AllowsTransparency="True"
        ResizeMode="CanResize"
        WindowStartupLocation="CenterOwner"
        Background="Transparent">

    <Window.Resources>
        <Style x:Key="TitleBarButton" TargetType="Button">
            <Setter Property="Width" Value="42"/>
            <Setter Property="Height" Value="30"/>
            <Setter Property="Foreground" Value="#F5F7FA"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Surface" Background="Transparent" CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Surface" Property="Background" Value="#151519"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="GhostButton" TargetType="Button">
            <Setter Property="Height" Value="42"/>
            <Setter Property="Padding" Value="18,0"/>
            <Setter Property="Background" Value="#111114"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#1C1C22"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="12">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#17171B"/>
                    <Setter Property="BorderBrush" Value="#282830"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="PrimaryButton" TargetType="Button" BasedOn="{StaticResource GhostButton}">
            <Setter Property="Background" Value="#FFFFFF"/>
            <Setter Property="Foreground" Value="#0A0A0C"/>
            <Setter Property="BorderBrush" Value="#FFFFFF"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#EBEDF0"/>
                    <Setter Property="BorderBrush" Value="#EBEDF0"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="InputLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#D6D9DE"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
        </Style>

        <Style x:Key="FieldHint" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#7F8690"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Margin" Value="0,8,0,0"/>
        </Style>

        <Style x:Key="InputTextBox" TargetType="TextBox">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="#0D0D10"/>
            <Setter Property="BorderBrush" Value="#1D1D22"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Padding" Value="14,12"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="12">
                            <ScrollViewer x:Name="PART_ContentHost"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="InputComboBox" TargetType="ComboBox">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="#0D0D10"/>
            <Setter Property="BorderBrush" Value="#1D1D22"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Padding" Value="14,10"/>
            <Setter Property="Height" Value="48"/>
        </Style>

        <Style TargetType="ComboBoxItem">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="#111114"/>
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="FontSize" Value="13"/>
            <Style.Triggers>
                <Trigger Property="IsHighlighted" Value="True">
                    <Setter Property="Background" Value="#1A1A20"/>
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#FFFFFF"/>
                    <Setter Property="Foreground" Value="#09090B"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="CategoryListBox" TargetType="ListBox">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Disabled"/>
            <Setter Property="ScrollViewer.VerticalScrollBarVisibility" Value="Disabled"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBox">
                        <ItemsPresenter/>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="CategoryListItemStyle" TargetType="ListBoxItem">
            <Setter Property="Foreground" Value="#F2F4F7"/>
            <Setter Property="Background" Value="#0D0D10"/>
            <Setter Property="BorderBrush" Value="#1D1D22"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="16,12"/>
            <Setter Property="Margin" Value="0,0,12,12"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="Surface"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="12"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Surface" Property="Background" Value="#141418"/>
                                <Setter TargetName="Surface" Property="BorderBrush" Value="#2B2B32"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Surface" Property="Background" Value="#FFFFFF"/>
                                <Setter TargetName="Surface" Property="BorderBrush" Value="#FFFFFF"/>
                                <Setter Property="Foreground" Value="#0A0A0C"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="InputSuffixBorder" TargetType="Border">
            <Setter Property="Background" Value="#111114"/>
            <Setter Property="BorderBrush" Value="#1D1D22"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Padding" Value="16,0"/>
            <Setter Property="Height" Value="44"/>
        </Style>

        <Style x:Key="SectionCard" TargetType="Border">
            <Setter Property="Background" Value="#0F0F12"/>
            <Setter Property="BorderBrush" Value="#19191E"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="24"/>
            <Setter Property="Padding" Value="28"/>
        </Style>

        <Style x:Key="PlatformToggleButton" TargetType="ToggleButton">
            <Setter Property="Background" Value="#0D0D10"/>
            <Setter Property="Foreground" Value="#F2F4F7"/>
            <Setter Property="BorderBrush" Value="#1D1D22"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Padding" Value="16,12"/>
            <Setter Property="Margin" Value="0,0,12,12"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border x:Name="Surface"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="12"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Surface" Property="Background" Value="#141418"/>
                                <Setter TargetName="Surface" Property="BorderBrush" Value="#2B2B32"/>
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Surface" Property="Background" Value="#FFFFFF"/>
                                <Setter TargetName="Surface" Property="BorderBrush" Value="#FFFFFF"/>
                                <Setter Property="Foreground" Value="#0A0A0C"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="RepeatButton">
            <Setter Property="Focusable" Value="False"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RepeatButton">
                        <Border Background="Transparent"/>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="Thumb">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Thumb">
                        <Border Background="#1F2026" CornerRadius="6"/>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ScrollBar">
            <Setter Property="Background" Value="#0A0A0D"/>
            <Setter Property="Width" Value="12"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollBar">
                        <Border Background="#0A0A0D" CornerRadius="6" Padding="2">
                            <Track x:Name="PART_Track" IsDirectionReversed="True">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton/>
                                </Track.DecreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb/>
                                </Track.Thumb>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton/>
                                </Track.IncreaseRepeatButton>
                            </Track>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="Orientation" Value="Horizontal">
                    <Setter Property="Height" Value="12"/>
                    <Setter Property="Width" Value="Auto"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Border Background="#09090B" BorderBrush="#17171B" BorderThickness="1" CornerRadius="16">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="34"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" Margin="12,0,10,0" Background="Transparent" MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Text="OYUN EKLE"
                           Foreground="#6E7682"
                           FontSize="11"
                           FontWeight="SemiBold"
                           VerticalAlignment="Center"
                           Margin="6,0,0,0"/>

                <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Style="{StaticResource TitleBarButton}" Click="MinimizeButton_Click">
                        <TextBlock Text="&#xE921;" FontFamily="Segoe MDL2 Assets" FontSize="10" Foreground="#F5F7FA"/>
                    </Button>
                    <Button Style="{StaticResource TitleBarButton}" Click="ToggleWindowStateButton_Click">
                        <TextBlock Text="&#xE922;" FontFamily="Segoe MDL2 Assets" FontSize="10" Foreground="#F5F7FA"/>
                    </Button>
                    <Button Click="CloseButton_Click">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource TitleBarButton}">
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border x:Name="Surface" Background="Transparent" CornerRadius="8">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="Surface" Property="Background" Value="#E81123"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </Button.Style>
                        <TextBlock Text="&#xE8BB;" FontFamily="Segoe MDL2 Assets" FontSize="10" Foreground="#F5F7FA"/>
                    </Button>
                </StackPanel>
            </Grid>

            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                <Grid Margin="28,24,28,28">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="26"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="24"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Button Grid.Column="0"
                                Content="← Geri Dön"
                                Style="{StaticResource GhostButton}"
                                Click="BackButton_Click"
                                Width="132"/>

                        <StackPanel Grid.Column="2" VerticalAlignment="Center">
                            <TextBlock Text="Yeni Oyun Kaydı"
                                       Foreground="White"
                                       FontSize="34"
                                       FontWeight="Bold"/>
                            <TextBlock Text="Yeni oyun kayıtı için geçerli bilgileri girin."
                                       Foreground="#9AA4B1"
                                       FontSize="13"
                                       Margin="0,10,0,0"/>
                        </StackPanel>
                    </Grid>

                    <Grid Grid.Row="2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="1.25*"/>
                            <ColumnDefinition Width="22"/>
                            <ColumnDefinition Width="1*"/>
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0" Style="{StaticResource SectionCard}">
                            <StackPanel>
                                <TextBlock Text="Temel Bilgiler" Foreground="White" FontSize="22" FontWeight="SemiBold"/>
                                <TextBlock Text="Oyunun mağaza sayfasında gösterilecek temel içeriklerini eksiksiz doldurun."
                                           Foreground="#8F98A5"
                                           FontSize="13"
                                           Margin="0,8,0,24"/>

                                <Grid Margin="0,0,0,18">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="18"/>
                                        <ColumnDefinition Width="210"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="Oyun Adı" Style="{StaticResource InputLabel}"/>
                                        <TextBox x:Name="txtTitle" Style="{StaticResource InputTextBox}"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="2">
                                        <TextBlock Text="Fiyat" Style="{StaticResource InputLabel}"/>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="10"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>

                                            <TextBox x:Name="txtPrice"
                                                     Style="{StaticResource InputTextBox}"
                                                     PreviewTextInput="PriceTextBox_PreviewTextInput"
                                                     LostFocus="PriceTextBox_LostFocus"/>

                                            <Border Grid.Column="2" Style="{StaticResource InputSuffixBorder}">
                                                <TextBlock Text="&#x20BA;"
                                                           Foreground="White"
                                                           FontSize="16"
                                                           FontWeight="SemiBold"
                                                           VerticalAlignment="Center"
                                                           HorizontalAlignment="Center"/>
                                            </Border>
                                        </Grid>
                                    </StackPanel>
                                </Grid>

                                <StackPanel Margin="0,0,0,18">
                                    <TextBlock Text="Kategori" Style="{StaticResource InputLabel}"/>
                                    <ListBox x:Name="lstCategory"
                                             Style="{StaticResource CategoryListBox}"
                                             ItemContainerStyle="{StaticResource CategoryListItemStyle}"
                                             SelectionMode="Single">
                                        <ListBox.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <WrapPanel/>
                                            </ItemsPanelTemplate>
                                        </ListBox.ItemsPanel>
                                    </ListBox>
                                </StackPanel>

                                <Grid Margin="0,0,0,18">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="18"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="Yapımcı" Style="{StaticResource InputLabel}"/>
                                        <TextBox x:Name="txtDeveloper" Style="{StaticResource InputTextBox}"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="2">
                                        <TextBlock Text="Yayıncı" Style="{StaticResource InputLabel}"/>
                                        <TextBox x:Name="txtPublisher" Style="{StaticResource InputTextBox}"/>
                                    </StackPanel>
                                </Grid>

                                <StackPanel Margin="0,0,0,18">
                                    <TextBlock Text="Platformlar" Style="{StaticResource InputLabel}"/>
                                    <WrapPanel>
                                        <ToggleButton x:Name="tglWindows" Content="Windows" Style="{StaticResource PlatformToggleButton}"/>
                                        <ToggleButton x:Name="tglMacOs" Content="macOS" Style="{StaticResource PlatformToggleButton}"/>
                                        <ToggleButton x:Name="tglLinux" Content="Linux" Style="{StaticResource PlatformToggleButton}"/>
                                    </WrapPanel>
                                    <TextBlock Text="Bir veya daha fazla platform seçin" Style="{StaticResource FieldHint}"/>
                                </StackPanel>

                                <StackPanel Margin="0,0,0,18">
                                    <TextBlock Text="Oyun Özellikleri" Style="{StaticResource InputLabel}"/>
                                    <ListBox x:Name="lstFeatures"
                                             Style="{StaticResource CategoryListBox}"
                                             ItemContainerStyle="{StaticResource CategoryListItemStyle}"
                                             SelectionMode="Multiple">
                                        <ListBox.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <WrapPanel/>
                                            </ItemsPanelTemplate>
                                        </ListBox.ItemsPanel>
                                    </ListBox>
                                    <TextBlock Text="İsterseniz bir veya daha fazla özellik seçin" Style="{StaticResource FieldHint}"/>
                                </StackPanel>

                                <Grid Margin="0,0,0,18">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="240"/>
                                        <ColumnDefinition Width="18"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="Çıkış Tarihi" Style="{StaticResource InputLabel}"/>
                                        <TextBox x:Name="txtReleaseDate" Style="{StaticResource InputTextBox}" PreviewTextInput="ReleaseDateTextBox_PreviewTextInput"/>
                                        <TextBlock Text="GG.AA.YYYY biçimini kullanın" Style="{StaticResource FieldHint}"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="2">
                                        <TextBlock Text="Oyun Fragmanı" Style="{StaticResource InputLabel}"/>
                                        <Border Background="#101014"
                                                BorderBrush="#1D1D22"
                                                BorderThickness="1"
                                                CornerRadius="14"
                                                Padding="16,14">
                                            <TextBlock x:Name="txtTrailerStatus"
                                                       Text="Fragman seçilmedi"
                                                       Foreground="White"
                                                       FontSize="14"
                                                       FontWeight="SemiBold"
                                                       TextWrapping="Wrap"/>
                                        </Border>
                                        <TextBlock Text="İsterseniz oyun fragmanı için video dosyası seçebilirsiniz" Style="{StaticResource FieldHint}"/>
                                    </StackPanel>
                                </Grid>

                                <StackPanel>
                                    <TextBlock Text="Açıklama" Style="{StaticResource InputLabel}"/>
                                    <TextBox x:Name="txtDescription"
                                             Style="{StaticResource InputTextBox}"
                                             Height="180"
                                             AcceptsReturn="True"
                                             TextWrapping="Wrap"
                                             VerticalScrollBarVisibility="Auto"/>
                                </StackPanel>

                                <Grid Margin="0,18,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="18"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="Minimum Sistem Gereksinimleri" Style="{StaticResource InputLabel}"/>
                                        <TextBox x:Name="txtMinimumRequirements"
                                                 Style="{StaticResource InputTextBox}"
                                                 Height="180"
                                                 AcceptsReturn="True"
                                                 TextWrapping="Wrap"
                                                 VerticalScrollBarVisibility="Auto"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="2">
                                        <TextBlock Text="Önerilen Sistem Gereksinimleri" Style="{StaticResource InputLabel}"/>
                                        <TextBox x:Name="txtRecommendedRequirements"
                                                 Style="{StaticResource InputTextBox}"
                                                 Height="180"
                                                 AcceptsReturn="True"
                                                 TextWrapping="Wrap"
                                                 VerticalScrollBarVisibility="Auto"/>
                                    </StackPanel>
                                </Grid>

                                <StackPanel Margin="0,18,0,0">
                                    <TextBlock Text="Desteklenen Diller" Style="{StaticResource InputLabel}"/>
                                    <TextBox x:Name="txtSupportedLanguages"
                                             Style="{StaticResource InputTextBox}"
                                             Height="140"
                                             AcceptsReturn="True"
                                             TextWrapping="Wrap"
                                             VerticalScrollBarVisibility="Auto"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <Border Grid.Column="2" Style="{StaticResource SectionCard}">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="24"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="18"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="18"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="18"/>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="26"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <StackPanel>
                                    <TextBlock Text="Medya Yönetimi" Foreground="White" FontSize="22" FontWeight="SemiBold"/>
                                    <TextBlock Text="Kapak görseli zorunludur."
                                               Foreground="#8F98A5"
                                               FontSize="13"
                                               Margin="0,8,0,0"/>
                                </StackPanel>

                                <Border Grid.Row="2"
                                        Background="#0D0D10"
                                        BorderBrush="#1D1D22"
                                        BorderThickness="1"
                                        CornerRadius="22"
                                        MinHeight="360"
                                        Padding="18">
                                    <Grid>
                                        <Image x:Name="imgCoverPreview"
                                               Stretch="UniformToFill"
                                               Visibility="Collapsed"/>
                                        <StackPanel x:Name="CoverPlaceholder"
                                                    HorizontalAlignment="Center"
                                                    VerticalAlignment="Center">
                                            <TextBlock Text="Kapak Görseli"
                                                       Foreground="White"
                                                       FontSize="20"
                                                       FontWeight="SemiBold"
                                                       HorizontalAlignment="Center"/>
                                            <TextBlock Text="Dikey ve yeterli çözünürlükte bir kapak görseli seçin"
                                                       Foreground="#8F98A5"
                                                       FontSize="13"
                                                       Margin="0,10,0,0"
                                                       HorizontalAlignment="Center"/>
                                        </StackPanel>
                                    </Grid>
                                </Border>

                                <Grid Grid.Row="4">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="12"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="12"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Button Grid.Column="0" Content="Ana Görsel Seç" Style="{StaticResource GhostButton}" Click="SelectCoverButton_Click"/>
                                    <Button Grid.Column="2" Content="Galeri Görselleri Seç" Style="{StaticResource GhostButton}" Click="SelectGalleryButton_Click"/>
                                    <Button Grid.Column="4" Content="Fragman Videosu Seç" Style="{StaticResource GhostButton}" Click="SelectTrailerButton_Click"/>
                                </Grid>

                                <Grid Grid.Row="6">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="14"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="14"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <Border Grid.Column="0"
                                            Background="#0D0D10"
                                            BorderBrush="#1D1D22"
                                            BorderThickness="1"
                                            CornerRadius="18"
                                            Padding="18">
                                        <StackPanel>
                                            <TextBlock Text="Ana Görsel" Foreground="#8F98A5" FontSize="11"/>
                                            <TextBlock x:Name="txtCoverStatus" Text="Henüz seçilmedi" Foreground="White" FontSize="14" FontWeight="SemiBold" Margin="0,8,0,0" TextWrapping="Wrap"/>
                                        </StackPanel>
                                    </Border>

                                    <Border Grid.Column="2"
                                            Background="#0D0D10"
                                            BorderBrush="#1D1D22"
                                            BorderThickness="1"
                                            CornerRadius="18"
                                            Padding="18">
                                        <StackPanel>
                                            <TextBlock Text="Fragman" Foreground="#8F98A5" FontSize="11"/>
                                            <TextBlock Text="{Binding ElementName=txtTrailerStatus, Path=Text}" Foreground="White" FontSize="14" FontWeight="SemiBold" Margin="0,8,0,0" TextWrapping="Wrap"/>
                                            <TextBlock Text="Bu alan opsiyoneldir" Style="{StaticResource FieldHint}"/>
                                        </StackPanel>
                                    </Border>

                                    <Border Grid.Column="4"
                                            Background="#0D0D10"
                                            BorderBrush="#1D1D22"
                                            BorderThickness="1"
                                            CornerRadius="18"
                                            Padding="18">
                                        <StackPanel>
                                            <TextBlock Text="Galeri Durumu" Foreground="#8F98A5" FontSize="11"/>
                                            <TextBlock x:Name="txtGalleryStatus" Text="0 / 8 görsel seçildi" Foreground="White" FontSize="14" FontWeight="SemiBold" Margin="0,8,0,0"/>
                                            <TextBlock Text="Kayıt için en az 3 en fazla 8 görsel gerekir" Style="{StaticResource FieldHint}"/>
                                        </StackPanel>
                                    </Border>
                                </Grid>

                                <Border Grid.Row="8"
                                        Background="#0D0D10"
                                        BorderBrush="#1D1D22"
                                        BorderThickness="1"
                                        CornerRadius="18"
                                        Padding="18">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="12"/>
                                            <RowDefinition Height="*"/>
                                        </Grid.RowDefinitions>
                                        <TextBlock Text="Seçilen Oyun Görselleri" Foreground="White" FontSize="15" FontWeight="SemiBold"/>
                                        <ListBox x:Name="lstGalleryFiles"
                                                 Grid.Row="2"
                                                 Background="Transparent"
                                                 BorderThickness="0"
                                                 Foreground="#D7DDE5"
                                                 FontSize="13"
                                                 Height="160"/>
                                    </Grid>
                                </Border>

                                <Grid Grid.Row="10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="12"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="12"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Button Grid.Column="0" Content="Geri Dön" Style="{StaticResource GhostButton}" Click="BackButton_Click"/>
                                    <Button Grid.Column="2" Content="Formu Temizle" Style="{StaticResource GhostButton}" Click="ResetButton_Click"/>
                                    <Button Grid.Column="4" Content="Kaydı Oluştur" Style="{StaticResource PrimaryButton}" Click="SaveButton_Click"/>
                                </Grid>
                            </Grid>
                        </Border>
                    </Grid>
                </Grid>
            </ScrollViewer>
        </Grid>
    </Border>
</Window>
