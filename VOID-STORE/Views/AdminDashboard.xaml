<Window x:Class="VOID_STORE.Views.AdminDashboard"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="VOID STORE ADMIN"
        Height="780"
        Width="1320"
        WindowStyle="None"
        AllowsTransparency="True"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen"
        Background="#0A0A0C">

    <Window.Resources>
        <LinearGradientBrush x:Key="PanelGlow" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#16181C" Offset="0"/>
            <GradientStop Color="#101114" Offset="1"/>
        </LinearGradientBrush>

        <Style x:Key="SideButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#A8A8B2"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Padding" Value="18,0,0,0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#17171B"/>
                    <Setter Property="Foreground" Value="White"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="SideButtonSelected" TargetType="Button" BasedOn="{StaticResource SideButton}">
            <Setter Property="Background" Value="#17171B"/>
            <Setter Property="Foreground" Value="White"/>
        </Style>

        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Background" Value="#1F7A3A"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#268E46"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="SecondaryButton" TargetType="Button">
            <Setter Property="Background" Value="#18181D"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#3A3A43"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#222228"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Border BorderBrush="#1B1B21" BorderThickness="1" CornerRadius="10">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="30"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" Background="Transparent" MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <TextBlock Text="VOID STORE ADMIN"
                           Foreground="#94949F"
                           FontWeight="SemiBold"
                           VerticalAlignment="Center"
                           Margin="16,0,0,0"/>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="_" Width="30" Foreground="White" Background="Transparent" BorderThickness="0" Click="MinimizeButton_Click" Cursor="Hand">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border x:Name="border" Background="Transparent">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="border" Property="Background" Value="#222228"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </Button.Style>
                    </Button>
                    <Button Content="X" Width="30" Foreground="White" Background="Transparent" BorderThickness="0" Click="CloseButton_Click" Cursor="Hand">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border x:Name="border" Background="Transparent">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="border" Property="Background" Value="#E81123"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </Button.Style>
                    </Button>
                </StackPanel>
            </Grid>

            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="250"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Background="#0D0D10" BorderBrush="#1B1B21" BorderThickness="0,1,1,0">
                    <Grid Margin="20,20,20,24">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <Image Grid.Row="0"
                               Source="../voidstoreimages/VOIDSTORE_NOBG_LOGO.png"
                               Height="120"
                               Margin="0,0,0,18"
                               HorizontalAlignment="Left"
                               RenderOptions.BitmapScalingMode="HighQuality"/>

                        <TextBlock Grid.Row="1"
                                   Text="Yönetim Paneli"
                                   Foreground="White"
                                   FontSize="26"
                                   FontWeight="Bold"
                                   Margin="0,0,0,22"/>

                        <StackPanel Grid.Row="2">
                            <Button Content="Genel Bakış" Height="46" Margin="0,0,0,10" Style="{StaticResource SideButtonSelected}" Click="PlaceholderButton_Click"/>
                            <Button Content="Oyunlar" Height="46" Style="{StaticResource SideButton}" Click="PlaceholderButton_Click"/>
                        </StackPanel>

                        <Button Grid.Row="3"
                                Height="42"
                                Content="Mağazaya Dön"
                                Style="{StaticResource SecondaryButton}"
                                Click="StoreButton_Click"/>
                    </Grid>
                </Border>

                <Grid Grid.Column="1" Margin="34,30,34,34">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <DockPanel Grid.Row="0" LastChildFill="False" Margin="0,0,0,28">
                        <StackPanel DockPanel.Dock="Left">
                            <TextBlock Text="Yönetim Paneli"
                                       Foreground="White"
                                       FontSize="32"
                                       FontWeight="Bold"/>
                            <TextBlock Text="Yönetici işlemlerini mağaza görünümünden ayrı ve kontrollü şekilde yönetin"
                                       Foreground="#8E8E98"
                                       FontSize="14"
                                       Margin="0,8,0,0"/>
                        </StackPanel>

                        <Button DockPanel.Dock="Right"
                                Width="170"
                                Height="42"
                                Content="Çıkış Yap"
                                Style="{StaticResource SecondaryButton}"
                                Click="LogoutButton_Click"/>
                    </DockPanel>

                    <Border Grid.Row="1"
                            Background="{StaticResource PanelGlow}"
                            BorderBrush="#24242B"
                            BorderThickness="1"
                            CornerRadius="14"
                            Padding="34">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0"
                                       Text="İçerik Yönetimi"
                                       Foreground="White"
                                       FontSize="30"
                                       FontWeight="Bold"/>

                            <TextBlock Grid.Row="1"
                                       Text="Oyun ekleme güncelleme silme ve listeleme işlemleri bu merkezden yönetilecek"
                                       Foreground="#A4A4AD"
                                       FontSize="14"
                                       TextWrapping="Wrap"
                                       Margin="0,12,0,22"/>

                            <Border Grid.Row="2"
                                    Background="#0F1012"
                                    BorderBrush="#212229"
                                    BorderThickness="1"
                                    CornerRadius="10"
                                    Padding="22"
                                    Margin="0,0,0,24">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="Oyun kataloğu"
                                                   Foreground="#8E8E98"
                                                   FontSize="13"/>
                                        <TextBlock Text="Kapak görselleri ve trailer bağlantıları oyun kayıtlarının içinde yönetilecek"
                                                   Foreground="White"
                                                   FontSize="20"
                                                   FontWeight="Bold"
                                                   TextWrapping="Wrap"
                                                   Margin="0,10,0,0"/>
                                    </StackPanel>

                                    <TextBlock Grid.Column="1"
                                               Text="01"
                                               Foreground="#2F7D47"
                                               FontSize="48"
                                               FontWeight="Bold"
                                               VerticalAlignment="Center"
                                               Margin="26,0,0,0"/>
                                </Grid>
                            </Border>

                            <UniformGrid Grid.Row="3" Columns="3">
                                <Button Height="46" Margin="0,0,12,0" Content="Oyunları Listele" Style="{StaticResource PrimaryButton}" Click="PlaceholderButton_Click"/>
                                <Button Height="46" Margin="0,0,12,0" Content="Yeni Oyun Ekle" Style="{StaticResource SecondaryButton}" Click="PlaceholderButton_Click"/>
                                <Button Height="46" Content="Mağazaya Dön" Style="{StaticResource SecondaryButton}" Click="StoreButton_Click"/>
                            </UniformGrid>
                        </Grid>
                    </Border>
                </Grid>
            </Grid>
        </Grid>
    </Border>
</Window>
