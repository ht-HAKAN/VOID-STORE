<Window x:Class="VOID_STORE.Views.CustomError"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Bilgi"
        Height="236"
        Width="420"
        WindowStyle="None"
        AllowsTransparency="True"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        Background="Transparent"
        Topmost="True">
    <Border Background="#0A0A0C" BorderBrush="#23232A" BorderThickness="1" CornerRadius="0">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="34"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" Background="#111114" MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <TextBlock x:Name="txtTitle"
                           Text="Bilgi"
                           Foreground="#F3F4F6"
                           FontWeight="Bold"
                           FontSize="12"
                           Margin="16,0,0,0"
                           VerticalAlignment="Center"/>
                <Button Width="42"
                        Height="34"
                        HorizontalAlignment="Right"
                        Background="Transparent"
                        BorderThickness="0"
                        Cursor="Hand"
                        Click="CloseButton_Click">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="Surface" Background="Transparent" CornerRadius="0">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="Surface" Property="Background" Value="#E81123"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </Button.Style>
                    <TextBlock Text="&#xE8BB;" FontFamily="Segoe MDL2 Assets" FontSize="10" Foreground="White"/>
                </Button>
            </Grid>

            <Grid Grid.Row="1" Margin="24">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock x:Name="txtMessage"
                           Foreground="#D8DCE2"
                           FontSize="14"
                           TextWrapping="Wrap"
                           TextAlignment="Center"
                           VerticalAlignment="Center"/>

                <Button x:Name="btnOk"
                        Grid.Row="1"
                        Height="40"
                        Width="110"
                        HorizontalAlignment="Center"
                        Margin="0,22,0,0"
                        Background="#E81123"
                        BorderBrush="#E81123"
                        BorderThickness="1"
                        Foreground="White"
                        FontSize="13"
                        FontWeight="SemiBold"
                        Cursor="Hand"
                        Click="CloseButton_Click"
                        Content="Tamam">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="BtnSurface"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="0">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="BtnSurface" Property="Opacity" Value="0.9"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </Grid>
        </Grid>
    </Border>
</Window>
