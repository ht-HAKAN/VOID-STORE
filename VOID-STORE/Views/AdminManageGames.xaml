<Window x:Class="VOID_STORE.Views.AdminManageGames"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="VOID STORE ADMIN"
        Height="980" Width="1680" MinHeight="920" MinWidth="1500"
        WindowStyle="None" AllowsTransparency="True" ResizeMode="CanResize"
        WindowStartupLocation="CenterOwner" Background="Transparent">
    <Window.Resources>
        <Style x:Key="TitleBarButton" TargetType="Button">
            <Setter Property="Width" Value="42"/><Setter Property="Height" Value="30"/><Setter Property="Foreground" Value="#F5F7FA"/><Setter Property="Background" Value="Transparent"/><Setter Property="BorderThickness" Value="0"/><Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template"><Setter.Value><ControlTemplate TargetType="Button"><Border x:Name="Surface" Background="Transparent" CornerRadius="8"><ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/></Border><ControlTemplate.Triggers><Trigger Property="IsMouseOver" Value="True"><Setter TargetName="Surface" Property="Background" Value="#141418"/></Trigger></ControlTemplate.Triggers></ControlTemplate></Setter.Value></Setter>
        </Style>
        <Style x:Key="GhostButton" TargetType="Button">
            <Setter Property="Height" Value="42"/><Setter Property="Padding" Value="18,0"/><Setter Property="Background" Value="#111114"/><Setter Property="Foreground" Value="White"/><Setter Property="BorderBrush" Value="#1C1C22"/><Setter Property="BorderThickness" Value="1"/><Setter Property="FontSize" Value="13"/><Setter Property="FontWeight" Value="SemiBold"/><Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template"><Setter.Value><ControlTemplate TargetType="Button"><Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="12"><ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/></Border></ControlTemplate></Setter.Value></Setter>
            <Style.Triggers><Trigger Property="IsMouseOver" Value="True"><Setter Property="Background" Value="#17171B"/><Setter Property="BorderBrush" Value="#282830"/></Trigger></Style.Triggers>
        </Style>
        <Style x:Key="PrimaryButton" TargetType="Button" BasedOn="{StaticResource GhostButton}">
            <Setter Property="Background" Value="#FFFFFF"/><Setter Property="Foreground" Value="#0A0A0C"/><Setter Property="BorderBrush" Value="#FFFFFF"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#1F8B3A"/>
                    <Setter Property="BorderBrush" Value="#1F8B3A"/>
                    <Setter Property="Foreground" Value="#FFFFFF"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="DangerButton" TargetType="Button" BasedOn="{StaticResource GhostButton}">
            <Setter Property="Background" Value="#A42A37"/><Setter Property="Foreground" Value="White"/><Setter Property="BorderBrush" Value="#A42A37"/>
            <Style.Triggers><Trigger Property="IsMouseOver" Value="True"><Setter Property="Background" Value="#BC3443"/><Setter Property="BorderBrush" Value="#BC3443"/></Trigger></Style.Triggers>
        </Style>
        <Style x:Key="TabButton" TargetType="Button">
            <Setter Property="Height" Value="40"/><Setter Property="Padding" Value="24,0"/><Setter Property="Background" Value="Transparent"/><Setter Property="Foreground" Value="#8F98A5"/><Setter Property="FontSize" Value="13"/><Setter Property="FontWeight" Value="SemiBold"/><Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Surface" Background="{TemplateBinding Background}" BorderThickness="0,0,0,2" BorderBrush="Transparent" Margin="0,0,12,0">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,0,0,2"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="InputTextBox" TargetType="TextBox">
            <Setter Property="Foreground" Value="White"/><Setter Property="Background" Value="#0D0D10"/><Setter Property="BorderBrush" Value="#1D1D22"/><Setter Property="BorderThickness" Value="1"/><Setter Property="FontSize" Value="14"/><Setter Property="Padding" Value="14,12"/>
            <Setter Property="Template"><Setter.Value><ControlTemplate TargetType="TextBox"><Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="12"><ScrollViewer x:Name="PART_ContentHost"/></Border></ControlTemplate></Setter.Value></Setter>
        </Style>
        <Style x:Key="SectionCard" TargetType="Border"><Setter Property="Background" Value="#0F0F12"/><Setter Property="BorderBrush" Value="#19191E"/><Setter Property="BorderThickness" Value="1"/><Setter Property="CornerRadius" Value="24"/><Setter Property="Padding" Value="28"/></Style>
        <Style x:Key="GameListItemStyle" TargetType="ListBoxItem">
            <Setter Property="Background" Value="#0C0C10"/><Setter Property="BorderBrush" Value="#17171C"/><Setter Property="BorderThickness" Value="1"/><Setter Property="Padding" Value="16"/><Setter Property="Margin" Value="0,0,0,12"/><Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Template"><Setter.Value><ControlTemplate TargetType="ListBoxItem"><Border x:Name="Surface" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="16" Padding="{TemplateBinding Padding}"><ContentPresenter/></Border><ControlTemplate.Triggers><Trigger Property="IsMouseOver" Value="True"><Setter TargetName="Surface" Property="Background" Value="#111116"/><Setter TargetName="Surface" Property="BorderBrush" Value="#23232B"/></Trigger><Trigger Property="IsSelected" Value="True"><Setter TargetName="Surface" Property="Background" Value="#15151B"/><Setter TargetName="Surface" Property="BorderBrush" Value="#FFFFFF"/></Trigger></ControlTemplate.Triggers></ControlTemplate></Setter.Value></Setter>
        </Style>
        <Style TargetType="RepeatButton"><Setter Property="Focusable" Value="False"/><Setter Property="Template"><Setter.Value><ControlTemplate TargetType="RepeatButton"><Border Background="Transparent"/></ControlTemplate></Setter.Value></Setter></Style>
        <Style TargetType="Thumb"><Setter Property="Template"><Setter.Value><ControlTemplate TargetType="Thumb"><Border Background="#1F2026" CornerRadius="6"/></ControlTemplate></Setter.Value></Setter></Style>
        <Style TargetType="ScrollBar"><Setter Property="Background" Value="#0A0A0D"/><Setter Property="Width" Value="12"/><Setter Property="Template"><Setter.Value><ControlTemplate TargetType="ScrollBar"><Border Background="#0A0A0D" CornerRadius="6" Padding="2"><Track x:Name="PART_Track" IsDirectionReversed="True"><Track.DecreaseRepeatButton><RepeatButton/></Track.DecreaseRepeatButton><Track.Thumb><Thumb/></Track.Thumb><Track.IncreaseRepeatButton><RepeatButton/></Track.IncreaseRepeatButton></Track></Border></ControlTemplate></Setter.Value></Setter><Style.Triggers><Trigger Property="Orientation" Value="Horizontal"><Setter Property="Height" Value="12"/><Setter Property="Width" Value="Auto"/></Trigger></Style.Triggers></Style>
        <Storyboard x:Key="FadeInAnimation">
            <DoubleAnimation Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="0:0:0.3"/>
        </Storyboard>
    </Window.Resources>
    <Border Background="#09090B" BorderBrush="#17171B" BorderThickness="1" CornerRadius="24">
        <Grid>
            <Grid.RowDefinitions><RowDefinition Height="34"/><RowDefinition Height="*"/></Grid.RowDefinitions>
            <Grid Grid.Row="0" Margin="12,0,10,0" MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                <TextBlock Text="OYUN YÖNETİMİ" Foreground="#6E7682" FontSize="11" FontWeight="SemiBold" VerticalAlignment="Center" Margin="6,0,0,0"/>
                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <Button Style="{StaticResource TitleBarButton}" Click="MinimizeButton_Click"><TextBlock Text="&#xE921;" FontFamily="Segoe MDL2 Assets" FontSize="10"/></Button>
                    <Button Style="{StaticResource TitleBarButton}" Click="ToggleWindowStateButton_Click"><TextBlock Text="&#xE922;" FontFamily="Segoe MDL2 Assets" FontSize="10"/></Button>
                    <Button Click="CloseButton_Click"><Button.Style><Style TargetType="Button" BasedOn="{StaticResource TitleBarButton}"><Setter Property="Template"><Setter.Value><ControlTemplate TargetType="Button"><Border x:Name="Surface" Background="Transparent" CornerRadius="8"><ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/></Border><ControlTemplate.Triggers><Trigger Property="IsMouseOver" Value="True"><Setter TargetName="Surface" Property="Background" Value="#E81123"/></Trigger></ControlTemplate.Triggers></ControlTemplate></Setter.Value></Setter></Style></Button.Style><TextBlock Text="&#xE8BB;" FontFamily="Segoe MDL2 Assets" FontSize="10"/></Button>
                </StackPanel>
            </Grid>
            <Grid Grid.Row="1" Margin="28,24,28,28">
                <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="20"/><RowDefinition Height="Auto"/><RowDefinition Height="20"/><RowDefinition Height="*"/></Grid.RowDefinitions>
                <Grid>
                    <Grid.ColumnDefinitions><ColumnDefinition Width="Auto"/><ColumnDefinition Width="24"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                    <Button Grid.Column="0" Width="132" Content="← Geri Dön" Style="{StaticResource GhostButton}" Click="BackButton_Click"/>
                    <StackPanel Grid.Column="2"><TextBlock x:Name="txtHeaderTitle" Text="Oyun Yönetimi" Foreground="White" FontSize="34" FontWeight="Bold"/><TextBlock x:Name="txtHeaderHint" Text="Onay bekleyen kayıtları ve görünürlük durumlarını buradan yönetin." Foreground="#9AA4B1" FontSize="13" Margin="0,10,0,0"/></StackPanel>
                </Grid>
                <StackPanel Grid.Row="2" Orientation="Horizontal">
                    <Button x:Name="btnPendingTab" Content="Onay Bekleyen" Style="{StaticResource TabButton}" Click="PendingTabButton_Click"/>
                    <Button x:Name="btnListedTab" Content="Listelenmiş Oyunlar" Style="{StaticResource TabButton}" Margin="12,0,0,0" Click="ListedTabButton_Click"/>
                    <Button x:Name="btnUnlistedTab" Content="Liste Dışı Oyunlar" Style="{StaticResource TabButton}" Margin="12,0,0,0" Click="UnlistedTabButton_Click"/>
                </StackPanel>
                <Grid Grid.Row="4">
                    <Grid.ColumnDefinitions><ColumnDefinition Width="400"/><ColumnDefinition Width="24"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                    <Border Grid.Column="0" Style="{StaticResource SectionCard}">
                        <Grid><Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="18"/><RowDefinition Height="Auto"/><RowDefinition Height="18"/><RowDefinition Height="*"/></Grid.RowDefinitions>
                            <StackPanel><TextBlock x:Name="txtListTitle" Text="Kayıt Listesi" Foreground="White" FontSize="22" FontWeight="SemiBold"/><TextBlock x:Name="txtListHint" Text="Soldaki listeden bir kayıt seçin" Foreground="#8F98A5" FontSize="13" Margin="0,8,0,0"/></StackPanel>
                            <TextBox x:Name="txtSearch" Grid.Row="2" Style="{StaticResource InputTextBox}" TextChanged="SearchTextBox_TextChanged"/>
                            <ListBox x:Name="lstGames" Grid.Row="4" Background="Transparent" BorderThickness="0" ItemContainerStyle="{StaticResource GameListItemStyle}" SelectionChanged="GamesList_SelectionChanged" ScrollViewer.HorizontalScrollBarVisibility="Disabled" ScrollViewer.VerticalScrollBarVisibility="Auto" ScrollViewer.CanContentScroll="True" VirtualizingStackPanel.IsVirtualizing="True" VirtualizingStackPanel.VirtualizationMode="Recycling" Margin="0,0,0,0" Padding="0,0,20,0">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <Grid>
                                            <Grid.ColumnDefinitions><ColumnDefinition Width="84"/><ColumnDefinition Width="14"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                            <Border Background="#111115" CornerRadius="12" Width="84" Height="112" ClipToBounds="True"><Grid><Image x:Name="PreviewImage" Source="{Binding CoverPreview}" Stretch="UniformToFill"/><TextBlock x:Name="PreviewPlaceholder" Text="VOID STORE" Foreground="#4A515C" FontSize="10" FontWeight="SemiBold" HorizontalAlignment="Center" VerticalAlignment="Center" Visibility="Collapsed"/></Grid></Border>
                                            <StackPanel Grid.Column="2" VerticalAlignment="Center">
                                                <Grid><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions><TextBlock Text="{Binding Title}" Foreground="White" FontSize="16" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" VerticalAlignment="Center"/><Border x:Name="ItemBadge" Grid.Column="1" Background="#182232" CornerRadius="10" Padding="8,4" Margin="8,0,0,0" Visibility="Collapsed"><TextBlock Text="{Binding BadgeText}" Foreground="#63A7FF" FontSize="10" FontWeight="SemiBold"/></Border></Grid>
                                                <TextBlock Text="{Binding Publisher}" Foreground="#8F98A5" FontSize="12" Margin="0,8,0,0"/>
                                                <TextBlock x:Name="StatusTextDisplay" Text="{Binding StatusText}" Foreground="#D7DDE5" FontSize="11" Margin="0,8,0,0"/>
                                            </StackPanel>
                                        </Grid>
                                        <DataTemplate.Triggers>
                                            <DataTrigger Binding="{Binding StatusText}" Value="Yayında">
                                                <Setter TargetName="StatusTextDisplay" Property="Foreground" Value="#2ECC71"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding StatusText}" Value="Sürüm Bekliyor">
                                                <Setter TargetName="StatusTextDisplay" Property="Foreground" Value="#63A7FF"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding BadgeText}" Value="">
                                                <Setter TargetName="ItemBadge" Property="Visibility" Value="Collapsed"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding BadgeText}" Value="{x:Null}">
                                                <Setter TargetName="ItemBadge" Property="Visibility" Value="Collapsed"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding BadgeText}" Value="Yeni Oyun">
                                                <Setter TargetName="ItemBadge" Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding BadgeText}" Value="Güncelleme">
                                                <Setter TargetName="ItemBadge" Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding BadgeText}" Value="Güncelleme Var">
                                                <Setter TargetName="ItemBadge" Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding CoverPreview}" Value="{x:Null}">
                                                <Setter TargetName="PreviewPlaceholder" Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding CoverPreview}" Value="{x:Null}">
                                                <Setter TargetName="PreviewImage" Property="Visibility" Value="Collapsed"/>
                                            </DataTrigger>
                                        </DataTemplate.Triggers>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                            <Grid x:Name="EmptyStateOverlay" Grid.Row="4" Visibility="Collapsed" Background="#0A0A0C" VerticalAlignment="Stretch">
                                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                    <TextBlock Text="&#xE721;" FontFamily="Segoe MDL2 Assets" Foreground="#1C1C22" FontSize="64" HorizontalAlignment="Center"/>
                                    <TextBlock Text="Burada hiçbir şey yok" Foreground="White" FontSize="18" FontWeight="Bold" Margin="0,20,0,0" HorizontalAlignment="Center"/>
                                    <TextBlock Text="Seçili bölümde görüntülenecek herhangi bir kayıt bulunamadı." Foreground="#8F98A5" FontSize="13" Margin="0,10,0,0" HorizontalAlignment="Center" TextAlignment="Center" TextWrapping="Wrap" MaxWidth="280"/>
                                </StackPanel>
                            </Grid>
                        </Grid>
                    </Border>
                    <Grid Grid.Column="2">
                        <ScrollViewer x:Name="DetailScroll" VerticalScrollBarVisibility="Auto" Visibility="Collapsed" Opacity="0">
                            <StackPanel>
                                <Border Style="{StaticResource SectionCard}">
                                    <StackPanel>
                                        <TextBlock x:Name="txtDetailTitle" Text="Detay" Foreground="White" FontSize="24" FontWeight="SemiBold"/>
                                        <TextBlock x:Name="txtDetailHint" Text="Seçilen kayıt burada görüntülenir." Foreground="#8F98A5" FontSize="13" Margin="0,10,0,0"/>
                                    </StackPanel>
                                </Border>
                                <Grid x:Name="CompareGrid" Margin="0,20,0,0" Visibility="Collapsed">
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="18"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                    <Border Grid.Column="0" Style="{StaticResource SectionCard}"><StackPanel><TextBlock Text="Yayındaki Sürüm" Foreground="White" FontSize="20" FontWeight="SemiBold"/><Border Width="280" Height="360" Background="#111115" CornerRadius="12" Margin="0,18,0,0" HorizontalAlignment="Left" ClipToBounds="True"><Image x:Name="imgLiveCover" Stretch="UniformToFill"/></Border><TextBlock x:Name="txtLiveSummary" Foreground="#D7DDE5" FontSize="13" Margin="0,18,0,0" TextWrapping="Wrap"/><WrapPanel x:Name="wpLivePlatforms" Margin="0,18,0,0"/><TextBlock Text="Açıklama" Foreground="White" FontSize="14" FontWeight="SemiBold" Margin="0,18,0,8"/><TextBlock x:Name="txtLiveDescription" Foreground="#AEB5C0" FontSize="13" TextWrapping="Wrap"/><TextBlock Text="Galeri Görselleri" Foreground="White" FontSize="14" FontWeight="SemiBold" Margin="0,18,0,8"/><ListBox x:Name="lstLiveGallery" Background="Transparent" BorderThickness="0" Foreground="#D7DDE5" Height="160"/></StackPanel></Border>
                                    <Border Grid.Column="2" Style="{StaticResource SectionCard}"><StackPanel><TextBlock Text="Gönderilen Değişiklikler" Foreground="White" FontSize="20" FontWeight="SemiBold"/><Border Width="280" Height="360" Background="#111115" CornerRadius="12" Margin="0,18,0,0" HorizontalAlignment="Left" ClipToBounds="True"><Image x:Name="imgIncomingCover" Stretch="UniformToFill"/></Border><TextBlock x:Name="txtIncomingSummary" Foreground="#D7DDE5" FontSize="13" Margin="0,18,0,0" TextWrapping="Wrap"/><WrapPanel x:Name="wpIncomingPlatforms" Margin="0,18,0,0"/><TextBlock Text="Açıklama" Foreground="White" FontSize="14" FontWeight="SemiBold" Margin="0,18,0,8"/><TextBlock x:Name="txtIncomingDescription" Foreground="#AEB5C0" FontSize="13" TextWrapping="Wrap"/><TextBlock Text="Galeri Görselleri" Foreground="White" FontSize="14" FontWeight="SemiBold" Margin="0,18,0,8"/><ListBox x:Name="lstIncomingGallery" Background="Transparent" BorderThickness="0" Foreground="#D7DDE5" Height="160"/></StackPanel></Border>
                                </Grid>
                                <Border x:Name="SingleStateCard" Style="{StaticResource SectionCard}" Margin="0,20,0,0" Visibility="Collapsed">
                                    <StackPanel><Border Width="320" Height="420" Background="#111115" CornerRadius="12" HorizontalAlignment="Left" ClipToBounds="True"><Image x:Name="imgSingleCover" Stretch="UniformToFill"/></Border><TextBlock x:Name="txtSingleSummary" Foreground="#D7DDE5" FontSize="13" Margin="0,18,0,0" TextWrapping="Wrap"/><WrapPanel x:Name="wpSinglePlatforms" Margin="0,18,0,0"/><TextBlock Text="Açıklama" Foreground="White" FontSize="14" FontWeight="SemiBold" Margin="0,18,0,8"/><TextBlock x:Name="txtSingleDescription" Foreground="#AEB5C0" FontSize="13" TextWrapping="Wrap"/><TextBlock Text="Galeri Görselleri" Foreground="White" FontSize="14" FontWeight="SemiBold" Margin="0,18,0,8"/><ListBox x:Name="lstSingleGallery" Background="Transparent" BorderThickness="0" Foreground="#D7DDE5" Height="180"/></StackPanel>
                                </Border>
                                <Grid Margin="0,20,0,0">
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="12"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                    <Button x:Name="btnSecondaryAction" Grid.Column="0" Style="{StaticResource DangerButton}" Visibility="Collapsed" Click="SecondaryActionButton_Click"/>
                                    <Button x:Name="btnPrimaryAction" Grid.Column="2" Style="{StaticResource PrimaryButton}" Visibility="Collapsed" Click="PrimaryActionButton_Click"/>
                                </Grid>
                            </StackPanel>
                        </ScrollViewer>
                        <Border x:Name="DetailPlaceholder" Style="{StaticResource SectionCard}">
                            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center"><TextBlock Text="Soldan bir kayıt seçin" Foreground="White" FontSize="28" FontWeight="Bold" HorizontalAlignment="Center"/><TextBlock x:Name="txtPlaceholderHint" Text="Seçilen kayıt burada görüntülenir." Foreground="#8F98A5" FontSize="13" Margin="0,12,0,0" HorizontalAlignment="Center" TextAlignment="Center"/></StackPanel>
                        </Border>
                    </Grid>
                </Grid>
            </Grid>
        </Grid>
    </Border>
</Window>

