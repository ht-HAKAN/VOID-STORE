<Window x:Class="VOID_STORE.Views.AdminCreateGame"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="VOID STORE ADMIN"
        Height="980"
        Width="1560"
        MinHeight="900"
        MinWidth="1360"
        WindowStyle="None"
        AllowsTransparency="True"
        ResizeMode="CanResize"
        WindowStartupLocation="CenterOwner"
        Background="Transparent">

    <Window.Resources>
        <Style x:Key="TitleBarButton" TargetType="Button">
            <Setter Property="Width" Value="42"/>
            <Setter Property="Height" Value="30"/>
            <Setter Property="Foreground" Value="#F5F7FA"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template"><Setter.Value><ControlTemplate TargetType="Button"><Border x:Name="Surface" Background="Transparent" CornerRadius="0"><ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/></Border><ControlTemplate.Triggers><Trigger Property="IsMouseOver" Value="True"><Setter TargetName="Surface" Property="Background" Value="#141418"/></Trigger></ControlTemplate.Triggers></ControlTemplate></Setter.Value></Setter>
        </Style>

        <Style x:Key="GhostButton" TargetType="Button">
            <Setter Property="Height" Value="42"/>
            <Setter Property="Padding" Value="18,0"/>
            <Setter Property="Background" Value="#111114"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#1C1C22"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template"><Setter.Value><ControlTemplate TargetType="Button"><Border x:Name="Surface" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="0" RenderTransformOrigin="0.5,0.5"><Border.RenderTransform><ScaleTransform ScaleX="1" ScaleY="1"/></Border.RenderTransform><ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/></Border><ControlTemplate.Triggers><Trigger Property="IsMouseOver" Value="True"><Trigger.EnterActions><BeginStoryboard><Storyboard><DoubleAnimation Storyboard.TargetName="Surface" Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)" To="1.02" Duration="0:0:0.1"/><DoubleAnimation Storyboard.TargetName="Surface" Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)" To="1.02" Duration="0:0:0.1"/></Storyboard></BeginStoryboard></Trigger.EnterActions><Trigger.ExitActions><BeginStoryboard><Storyboard><DoubleAnimation Storyboard.TargetName="Surface" Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)" To="1" Duration="0:0:0.1"/><DoubleAnimation Storyboard.TargetName="Surface" Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)" To="1" Duration="0:0:0.1"/></Storyboard></BeginStoryboard></Trigger.ExitActions></Trigger></ControlTemplate.Triggers></ControlTemplate></Setter.Value></Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#17171B"/>
                    <Setter Property="BorderBrush" Value="#282830"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="PrimaryButton" TargetType="Button" BasedOn="{StaticResource GhostButton}">
            <Setter Property="Background" Value="#FFFFFF"/>
            <Setter Property="Foreground" Value="#0A0A0C"/>
            <Setter Property="BorderBrush" Value="#FFFFFF"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#EBEDF0"/>
                    <Setter Property="BorderBrush" Value="#EBEDF0"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="InputLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#D6D9DE"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
        </Style>

        <Style x:Key="FieldHint" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#7F8690"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Margin" Value="0,8,0,0"/>
        </Style>

        <Style x:Key="InputTextBox" TargetType="TextBox">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="#0D0D10"/>
            <Setter Property="BorderBrush" Value="#1D1D22"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Padding" Value="14,12"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="0">
                            <ScrollViewer x:Name="PART_ContentHost"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="InputComboBox" TargetType="ComboBox">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="#0D0D10"/>
            <Setter Property="BorderBrush" Value="#1D1D22"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Padding" Value="14,10"/>
            <Setter Property="Height" Value="48"/>
        </Style>

        <Style TargetType="ComboBoxItem">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="#111114"/>
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="FontSize" Value="13"/>
            <Style.Triggers>
                <Trigger Property="IsHighlighted" Value="True">
                    <Setter Property="Background" Value="#1A1A20"/>
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#FFFFFF"/>
                    <Setter Property="Foreground" Value="#09090B"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="CategoryListBox" TargetType="ListBox">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Disabled"/>
            <Setter Property="ScrollViewer.VerticalScrollBarVisibility" Value="Disabled"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBox">
                        <ItemsPresenter/>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="CategoryListItemStyle" TargetType="ListBoxItem">
            <Setter Property="Foreground" Value="#F2F4F7"/>
            <Setter Property="Background" Value="#0D0D10"/>
            <Setter Property="BorderBrush" Value="#1D1D22"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="16,12"/>
            <Setter Property="Margin" Value="0,0,12,12"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="Surface"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="0"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Surface" Property="Background" Value="#141418"/>
                                <Setter TargetName="Surface" Property="BorderBrush" Value="#2B2B32"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Surface" Property="Background" Value="#FFFFFF"/>
                                <Setter TargetName="Surface" Property="BorderBrush" Value="#FFFFFF"/>
                                <Setter Property="Foreground" Value="#0A0A0C"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="InputSuffixBorder" TargetType="Border">
            <Setter Property="Background" Value="#111114"/>
            <Setter Property="BorderBrush" Value="#1D1D22"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="0"/>
            <Setter Property="Padding" Value="16,0"/>
            <Setter Property="Height" Value="44"/>
        </Style>
        <Style x:Key="ModernSwitch" TargetType="ToggleButton">
            <Setter Property="Width" Value="54"/>
            <Setter Property="Height" Value="28"/>
            <Setter Property="Background" Value="#17171B"/>
            <Setter Property="BorderBrush" Value="#282830"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border x:Name="Border" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="0">
                            <Grid>
                                <Border x:Name="Dot" HorizontalAlignment="Left" Width="20" Height="20" Background="#3F444D" Margin="3,0,0,0" CornerRadius="0">
                                    <Border.RenderTransform>
                                        <TranslateTransform X="0"/>
                                    </Border.RenderTransform>
                                </Border>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="#FFFFFF"/>
                                <Setter TargetName="Dot" Property="Background" Value="#0A0A0C"/>
                                <Trigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="Dot" Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.X)" To="26" Duration="0:0:0.15"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.EnterActions>
                                <Trigger.ExitActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="Dot" Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.X)" To="0" Duration="0:0:0.15"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.ExitActions>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SectionCard" TargetType="Border">
            <Setter Property="Background" Value="#0F0F12"/>
            <Setter Property="BorderBrush" Value="#19191E"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="16"/>
            <Setter Property="Padding" Value="28"/>
        </Style>

        <Style x:Key="PlatformToggleButton" TargetType="ToggleButton">
            <Setter Property="Background" Value="#0D0D10"/>
            <Setter Property="Foreground" Value="#F2F4F7"/>
            <Setter Property="BorderBrush" Value="#1D1D22"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Padding" Value="16,12"/>
            <Setter Property="Margin" Value="0,0,12,12"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border x:Name="Surface"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="0"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Surface" Property="Background" Value="#141418"/>
                                <Setter TargetName="Surface" Property="BorderBrush" Value="#2B2B32"/>
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Surface" Property="Background" Value="#FFFFFF"/>
                                <Setter TargetName="Surface" Property="BorderBrush" Value="#FFFFFF"/>
                                <Setter Property="Foreground" Value="#0A0A0C"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Modern DatePicker Style (Ultimate Jilet Version) -->
        <Style TargetType="DatePickerTextBox">
            <Setter Property="IsReadOnly" Value="True"/>
            <Setter Property="Focusable" Value="False"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Padding" Value="12,0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="DatePickerTextBox">
                        <Border Background="Transparent">
                            <VisualStateManager.VisualStateGroups>
                                <VisualStateGroup x:Name="CommonStates">
                                    <VisualState x:Name="Normal"/>
                                    <VisualState x:Name="MouseOver"/>
                                    <VisualState x:Name="Disabled"/>
                                </VisualStateGroup>
                            </VisualStateManager.VisualStateGroups>
                            <ScrollViewer x:Name="PART_ContentHost"
                                          Focusable="False"
                                          HorizontalScrollBarVisibility="Hidden"
                                          VerticalScrollBarVisibility="Hidden"
                                          VerticalAlignment="Center"
                                          Foreground="White"
                                          Background="Transparent"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ModernDatePicker" TargetType="DatePicker">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="#111115"/>
            <Setter Property="BorderBrush" Value="#1C1C22"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Height" Value="44"/>
            <Setter Property="Width" Value="200"/>
            <Setter Property="HorizontalAlignment" Value="Left"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="DatePicker">
                        <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="0">
                            <Grid x:Name="PART_Root">
                                <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="34"/></Grid.ColumnDefinitions>
                                <DatePickerTextBox x:Name="PART_TextBox" Grid.Column="0" Focusable="False" IsReadOnly="True"/>
                                <Button x:Name="PART_Button" Grid.Column="1" Background="Transparent" BorderThickness="0" Cursor="Hand">
                                    <TextBlock Text="&#xE787;" FontFamily="Segoe MDL2 Assets" Foreground="#8F98A5" VerticalAlignment="Center" HorizontalAlignment="Center" FontSize="14"/>
                                </Button>
                                <Popup x:Name="PART_Popup" AllowsTransparency="True" Placement="Bottom" StaysOpen="False"/>
                            </Grid>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="CategoryToggleStyle" TargetType="ToggleButton">
            <Setter Property="Background" Value="#111114"/>
            <Setter Property="Foreground" Value="#8F98A5"/>
            <Setter Property="BorderBrush" Value="#1D1D22"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="16,8"/>
            <Setter Property="Margin" Value="0,0,8,8"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border x:Name="Surface" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="0" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Surface" Property="Background" Value="#1A1A20"/>
                                <Setter TargetName="Surface" Property="BorderBrush" Value="#3F444D"/>
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Surface" Property="Background" Value="#FFFFFF"/>
                                <Setter TargetName="Surface" Property="BorderBrush" Value="#FFFFFF"/>
                                <Setter Property="Foreground" Value="#0A0A0C"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="RepeatButton"><Setter Property="Focusable" Value="False"/><Setter Property="Template"><Setter.Value><ControlTemplate TargetType="RepeatButton"><Border Background="Transparent"/></ControlTemplate></Setter.Value></Setter></Style>
        <Style TargetType="Thumb"><Setter Property="Template"><Setter.Value><ControlTemplate TargetType="Thumb"><Border Background="#1F2026" CornerRadius="0"/></ControlTemplate></Setter.Value></Setter></Style>
        <Style TargetType="ScrollBar"><Setter Property="Background" Value="#0A0A0D"/><Setter Property="Width" Value="12"/><Setter Property="Template"><Setter.Value><ControlTemplate TargetType="ScrollBar"><Border Background="#0A0A0D" CornerRadius="0" Padding="2"><Track x:Name="PART_Track" IsDirectionReversed="True"><Track.DecreaseRepeatButton><RepeatButton/></Track.DecreaseRepeatButton><Track.Thumb><Thumb/></Track.Thumb><Track.IncreaseRepeatButton><RepeatButton/></Track.IncreaseRepeatButton></Track></Border></ControlTemplate></Setter.Value></Setter><Style.Triggers><Trigger Property="Orientation" Value="Horizontal"><Setter Property="Height" Value="12"/><Setter Property="Width" Value="Auto"/></Trigger></Style.Triggers></Style>

        <Style TargetType="TabControl">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabControl">
                        <Grid KeyboardNavigation.TabNavigation="Local">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <TabPanel Grid.Row="0" IsItemsHost="True" Margin="0,0,0,24"/>
                            <Border Grid.Row="1" Background="Transparent">
                                <ContentPresenter x:Name="PART_SelectedContentHost" ContentSource="SelectedContent"/>
                            </Border>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="TabItem">
            <Setter Property="Background" Value="#0D0D10"/>
            <Setter Property="Foreground" Value="#8F98A5"/>
            <Setter Property="BorderBrush" Value="#1D1D22"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="24,14"/>
            <Setter Property="MinWidth" Value="160"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Margin" Value="0,0,10,0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Border x:Name="Surface" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" Margin="0" Padding="{TemplateBinding Padding}" CornerRadius="0">
                            <ContentPresenter x:Name="Content" ContentSource="Header" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Surface" Property="Background" Value="#141418"/>
                                <Setter TargetName="Surface" Property="BorderBrush" Value="#2B2B32"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Surface" Property="Background" Value="#FFFFFF"/>
                                <Setter TargetName="Surface" Property="BorderBrush" Value="#FFFFFF"/>
                                <Setter Property="Foreground" Value="#0A0A0C"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.3"/>
                            </Trigger>
                            <DataTrigger Binding="{Binding RelativeSource={RelativeSource Self}, Path=Tag}" Value="Valid">
                                <Setter TargetName="Surface" Property="BorderBrush" Value="#2ECC71"/>
                                <Setter TargetName="Surface" Property="Background" Value="#0A2215"/>
                                <Setter Property="Foreground" Value="#2ECC71"/>
                            </DataTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Calendar Premium Dark Style - mavi highlight kaldır -->
        <Style TargetType="CalendarDayButton">
            <Setter Property="Background" Value="Transparent"/><Setter Property="Foreground" Value="#D6D9DE"/><Setter Property="FontSize" Value="12"/><Setter Property="MinWidth" Value="40"/><Setter Property="MinHeight" Value="40"/>
            <Setter Property="Template"><Setter.Value><ControlTemplate TargetType="CalendarDayButton"><Border x:Name="Bd" Background="{TemplateBinding Background}" CornerRadius="0"><ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/></Border><ControlTemplate.Triggers><Trigger Property="IsMouseOver" Value="True"><Setter TargetName="Bd" Property="Background" Value="#1A1A22"/></Trigger><Trigger Property="IsSelected" Value="True"><Setter TargetName="Bd" Property="Background" Value="#FFFFFF"/><Setter Property="Foreground" Value="#0A0A0C"/></Trigger><Trigger Property="IsToday" Value="True"><Setter TargetName="Bd" Property="BorderBrush" Value="#D6D9DE"/><Setter TargetName="Bd" Property="BorderThickness" Value="1"/></Trigger><Trigger Property="IsBlackedOut" Value="True"><Setter Property="Foreground" Value="#333340"/></Trigger><Trigger Property="IsInactive" Value="True"><Setter Property="Foreground" Value="#464650"/></Trigger></ControlTemplate.Triggers></ControlTemplate></Setter.Value></Setter>
        </Style>
        <Style TargetType="CalendarButton">
            <Setter Property="Background" Value="Transparent"/><Setter Property="Foreground" Value="#D6D9DE"/><Setter Property="FontSize" Value="12"/>
            <Setter Property="Template"><Setter.Value><ControlTemplate TargetType="CalendarButton"><Border x:Name="Bd" Background="{TemplateBinding Background}" CornerRadius="0"><ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/></Border><ControlTemplate.Triggers><Trigger Property="IsMouseOver" Value="True"><Setter TargetName="Bd" Property="Background" Value="#1A1A22"/></Trigger><Trigger Property="HasSelectedDays" Value="True"><Setter TargetName="Bd" Property="Background" Value="#FFFFFF"/><Setter Property="Foreground" Value="#0A0A0C"/></Trigger></ControlTemplate.Triggers></ControlTemplate></Setter.Value></Setter>
        </Style>
        <Style TargetType="Calendar">
            <Setter Property="Background" Value="#0F0F13"/><Setter Property="BorderBrush" Value="#1C1C22"/><Setter Property="BorderThickness" Value="1"/><Setter Property="Foreground" Value="#D6D9DE"/>
        </Style>
    </Window.Resources>

    <Border Background="#09090B" BorderBrush="#17171B" BorderThickness="1" CornerRadius="0">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="34"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" Margin="12,0,10,0" Background="Transparent" MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Text="OYUN EKLE"
                           Foreground="#6E7682"
                           FontSize="11"
                           FontWeight="SemiBold"
                           VerticalAlignment="Center"
                           Margin="6,0,0,0"/>

                <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Style="{StaticResource TitleBarButton}" Click="MinimizeButton_Click">
                        <TextBlock Text="&#xE921;" FontFamily="Segoe MDL2 Assets" FontSize="10" Foreground="#F5F7FA"/>
                    </Button>
                    <Button Style="{StaticResource TitleBarButton}" Click="ToggleWindowStateButton_Click">
                        <TextBlock Text="&#xE922;" FontFamily="Segoe MDL2 Assets" FontSize="10" Foreground="#F5F7FA"/>
                    </Button>
                    <Button Click="CloseButton_Click">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource TitleBarButton}">
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border x:Name="Surface" Background="Transparent" CornerRadius="0">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="Surface" Property="Background" Value="#E81123"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </Button.Style>
                        <TextBlock Text="&#xE8BB;" FontFamily="Segoe MDL2 Assets" FontSize="10" Foreground="#F5F7FA"/>
                    </Button>
                </StackPanel>
            </Grid>

            <Grid Grid.Row="1" Margin="28,24,28,28">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="26"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Header -->
                <Grid Grid.Row="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="24"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Button Grid.Column="0" Content="← Geri Dön" Style="{StaticResource GhostButton}" Click="BackButton_Click" Width="132"/>
                    <StackPanel Grid.Column="2" VerticalAlignment="Center">
                        <TextBlock Text="Yeni Oyun Kaydı" Foreground="White" FontSize="34" FontWeight="Bold"/>
                        <TextBlock Text="Yeni oyun kayıtı için geçerli bilgileri girin." Foreground="#9AA4B1" FontSize="13" Margin="0,10,0,0"/>
                    </StackPanel>
                </Grid>

                <TabControl x:Name="AdminTabControl" Grid.Row="2">
                    <!-- Tab 1: Genel Bilgiler -->
                    <TabItem x:Name="TabItemGenel" Header="Genel Bilgiler">
                        <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="0,0,8,0">
                            <StackPanel Margin="0,0,0,20">
                                <!-- Row 1: Title & Price -->
                                <Border Style="{StaticResource SectionCard}" Margin="0,0,0,16" Padding="20">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="32"/>
                                            <ColumnDefinition Width="300"/>
                                        </Grid.ColumnDefinitions>
                                        
                                        <StackPanel Grid.Column="0">
                                            <TextBlock Text="Oyun Adı" Style="{StaticResource InputLabel}"/>
                                            <TextBox x:Name="txtTitle" Style="{StaticResource InputTextBox}" TextChanged="Input_Changed"/>
                                            <TextBlock x:Name="txtTitleError" Text="* Oyun adı boş bırakılamaz" Foreground="#FF5555" FontSize="10" Margin="4,4,0,0" Visibility="Collapsed"/>
                                        </StackPanel>

                                        <StackPanel Grid.Column="2">
                                            <TextBlock Text="Fiyatlandırma" Style="{StaticResource InputLabel}" Margin="0,0,0,8"/>
                                            <Grid x:Name="gridPriceInput">
                                                <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="8"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                                <TextBox x:Name="txtPrice" Style="{StaticResource InputTextBox}" PreviewTextInput="OnlyNumbers_PreviewTextInput" LostFocus="PriceTextBox_LostFocus" TextChanged="Input_Changed" MaxLength="4"/>
                                                <Border Grid.Column="2" Style="{StaticResource InputSuffixBorder}" Height="44" CornerRadius="0"><TextBlock Text="&#x20BA;" Foreground="White" FontSize="16" VerticalAlignment="Center"/></Border>
                                            </Grid>
                                            <TextBlock x:Name="txtFreeHint" Text="Oyun ücretsiz olarak oynanabilir" Foreground="#2ECC71" FontSize="11" Margin="4,4,0,0" Visibility="Collapsed"/>
                                        </StackPanel>
                                    </Grid>
                                </Border>

                                <!-- Row 2: Developer, Publisher & Release Date -->
                                <Border Style="{StaticResource SectionCard}" Margin="0,0,0,16" Padding="20">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="20"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="20"/>
                                            <ColumnDefinition Width="200"/>
                                        </Grid.ColumnDefinitions>
                                        
                                        <StackPanel Grid.Column="0">
                                            <TextBlock Text="Yapımcı" Style="{StaticResource InputLabel}"/>
                                            <TextBox x:Name="txtDeveloper" Style="{StaticResource InputTextBox}" TextChanged="Input_Changed"/>
                                        </StackPanel>

                                        <StackPanel Grid.Column="2">
                                            <TextBlock Text="Yayıncı" Style="{StaticResource InputLabel}"/>
                                            <TextBox x:Name="txtPublisher" Style="{StaticResource InputTextBox}" TextChanged="Input_Changed"/>
                                        </StackPanel>

                                        <StackPanel Grid.Column="4">
                                            <TextBlock Text="Çıkış Tarihi" Style="{StaticResource InputLabel}"/>
                                            <DatePicker x:Name="dpReleaseDate" Style="{StaticResource ModernDatePicker}"/>
                                        </StackPanel>
                                    </Grid>
                                </Border>

                                <!-- Row 3: Categories -->
                                <Border Style="{StaticResource SectionCard}" Margin="0,0,0,16" Padding="20">
                                    <StackPanel>
                                        <TextBlock Text="Kategoriler (Maksimum 3)" Style="{StaticResource InputLabel}"/>
                                        <WrapPanel x:Name="wpCategories" Margin="0,8,0,0"/>
                                    </StackPanel>
                                </Border>

                                <!-- Row 4: Discount Management -->
                                <Border x:Name="borderDiscount" Style="{StaticResource SectionCard}" Margin="0,0,0,16" Padding="20">
                                    <StackPanel>
                                        <TextBlock Text="İNDİRİM YÖNETİMİ" Foreground="#63A7FF" FontSize="12" FontWeight="Bold" Margin="0,0,0,16"/>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="150"/>
                                                <ColumnDefinition Width="20"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="20"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            
                                            <StackPanel Grid.Column="0">
                                                <TextBlock Text="Oran (%)" Foreground="#D6D9DE" Style="{StaticResource InputLabel}"/>
                                                <TextBox x:Name="txtDiscountRate" Style="{StaticResource InputTextBox}" Text="0" MaxLength="3" PreviewTextInput="OnlyNumbers_PreviewTextInput"/>
                                            </StackPanel>

                                            <StackPanel Grid.Column="2">
                                                <TextBlock Text="Başlangıç Tarihi" Foreground="#D6D9DE" Style="{StaticResource InputLabel}"/>
                                                <DatePicker x:Name="dpDiscountStart" Style="{StaticResource ModernDatePicker}"/>
                                            </StackPanel>

                                            <StackPanel Grid.Column="4">
                                                <TextBlock Text="Bitiş Tarihi" Foreground="#D6D9DE" Style="{StaticResource InputLabel}"/>
                                                <DatePicker x:Name="dpDiscountEnd" Style="{StaticResource ModernDatePicker}"/>
                                            </StackPanel>
                                        </Grid>
                                    </StackPanel>
                                </Border>

                                <!-- Row 5: Description -->
                                <Border Style="{StaticResource SectionCard}" Padding="20">
                                    <StackPanel>
                                        <TextBlock Text="Oyun Açıklaması" Foreground="#D6D9DE" Style="{StaticResource InputLabel}"/>
                                        <TextBox x:Name="txtDescription" Style="{StaticResource InputTextBox}" Height="120" AcceptsReturn="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto" TextChanged="Input_Changed"/>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </ScrollViewer>
                    </TabItem>

                    <!-- Tab 2: Medya Yönetimi -->
                    <TabItem x:Name="TabItemMedya" Header="Medya Yönetimi" IsEnabled="False">
                        <Grid Margin="0,0,12,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="320"/>
                                <ColumnDefinition Width="24"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            
                            <StackPanel Grid.Column="0">
                                <Border Style="{StaticResource SectionCard}" Padding="12" MinHeight="420">
                                    <Grid>
                                        <Image x:Name="imgCoverPreview" Stretch="UniformToFill" Visibility="Collapsed"/>
                                        <StackPanel x:Name="CoverPlaceholder" VerticalAlignment="Center">
                                            <TextBlock Text="&#xE722;" FontFamily="Segoe MDL2 Assets" FontSize="48" Foreground="#1C1C22" HorizontalAlignment="Center"/>
                                            <TextBlock Text="Kapak Görseli" Foreground="White" FontSize="16" FontWeight="SemiBold" HorizontalAlignment="Center" Margin="0,16,0,0"/>
                                            <TextBlock Text="Dikey, yüksek çözünürlük" Foreground="#8F98A5" FontSize="11" HorizontalAlignment="Center" Margin="0,8,0,0"/>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                                <Button Content="Kapak Seç" Style="{StaticResource GhostButton}" Margin="0,12,0,0" Click="SelectCoverButton_Click"/>
                                <Border Background="#111115" Margin="0,12,0,0" Padding="12" BorderThickness="1" BorderBrush="#1C1C22">
                                    <TextBlock x:Name="txtCoverStatus" Text="Henüz seçilmedi" Foreground="#8F98A5" FontSize="12" TextWrapping="Wrap" HorizontalAlignment="Center"/>
                                </Border>
                            </StackPanel>

                            <StackPanel Grid.Column="2">
                                <Border Style="{StaticResource SectionCard}" Padding="20">
                                    <StackPanel>
                                        <Grid Margin="0,0,0,20">
                                            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="12"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                            <Button Grid.Column="0" Content="Galeri Görselleri Seç" Style="{StaticResource GhostButton}" Click="SelectGalleryButton_Click"/>
                                            <Button Grid.Column="2" Content="Fragman Videosu Seç" Style="{StaticResource GhostButton}" Click="SelectTrailerButton_Click"/>
                                        </Grid>
                                        
                                        <Grid Margin="0,0,0,20">
                                            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="12"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                            <Border Grid.Column="0" Background="#0D0D10" Padding="12" BorderThickness="1" BorderBrush="#1C1C22">
                                                <StackPanel><TextBlock Text="Galeri Durumu" Foreground="#8F98A5" FontSize="11"/><TextBlock x:Name="txtGalleryStatus" Text="0 / 8 görsel" Foreground="White" FontSize="14" FontWeight="SemiBold" Margin="0,4,0,0"/></StackPanel>
                                            </Border>
                                            <Border Grid.Column="2" Background="#0D0D10" Padding="12" BorderThickness="1" BorderBrush="#1C1C22">
                                                <StackPanel><TextBlock Text="Fragman Durumu" Foreground="#8F98A5" FontSize="11"/><TextBlock x:Name="txtTrailerStatus" Text="Seçilmedi" Foreground="White" FontSize="14" FontWeight="SemiBold" Margin="0,4,0,0" TextTrimming="CharacterEllipsis"/></StackPanel>
                                            </Border>
                                        </Grid>

                                        <TextBlock Text="Seçilen Galeri Dosyaları" Style="{StaticResource InputLabel}"/>
                                        <ListBox x:Name="lstGalleryFiles" Background="#0D0D10" BorderThickness="1" BorderBrush="#1C1C22" Height="200" Foreground="#D7DDE5" FontSize="12" Padding="8"/>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </Grid>
                    </TabItem>

                    <!-- Tab 3: Sistem & Platform -->
                    <TabItem x:Name="TabItemSistem" Header="Sistem &amp; Platform" IsEnabled="False">
                        <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="0,0,8,0">
                            <Grid Margin="0,0,12,0">
                                <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="24"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
                                
                                <Border Grid.Row="0" Style="{StaticResource SectionCard}">
                                    <StackPanel>
                                        <Grid Margin="0,0,0,24">
                                            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="32"/><ColumnDefinition Width="2*"/></Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0">
                                                <TextBlock Text="Platformlar" Style="{StaticResource InputLabel}"/>
                                                <WrapPanel><ToggleButton x:Name="tglWindows" Content="Windows" Style="{StaticResource PlatformToggleButton}"/><ToggleButton x:Name="tglMacOs" Content="macOS" Style="{StaticResource PlatformToggleButton}"/><ToggleButton x:Name="tglLinux" Content="Linux" Style="{StaticResource PlatformToggleButton}"/></WrapPanel>
                                            </StackPanel>
                                            <StackPanel Grid.Column="2">
                                                <TextBlock Text="Özellikler" Style="{StaticResource InputLabel}"/>
                                                <ListBox x:Name="lstFeatures" Style="{StaticResource CategoryListBox}" ItemContainerStyle="{StaticResource CategoryListItemStyle}" SelectionMode="Multiple"><ListBox.ItemsPanel><ItemsPanelTemplate><WrapPanel/></ItemsPanelTemplate></ListBox.ItemsPanel></ListBox>
                                            </StackPanel>
                                        </Grid>
                                        


                                        <StackPanel>
                                            <TextBlock Text="Desteklenen Diller" Style="{StaticResource InputLabel}"/>
                                            <TextBox x:Name="txtSupportedLanguages" Style="{StaticResource InputTextBox}" Height="100" AcceptsReturn="True" TextWrapping="Wrap"/>
                                        </StackPanel>
                                    </StackPanel>
                                </Border>

                                <Border Grid.Row="2" Style="{StaticResource SectionCard}">
                                    <Grid>
                                        <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="24"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0">
                                            <TextBlock Text="Minimum Gereksinimler" Style="{StaticResource InputLabel}"/>
                                            <TextBox x:Name="txtMinimumRequirements" Style="{StaticResource InputTextBox}" Height="220" AcceptsReturn="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto"/>
                                        </StackPanel>
                                        <StackPanel Grid.Column="2">
                                            <TextBlock Text="Önerilen Gereksinimler" Style="{StaticResource InputLabel}"/>
                                            <TextBox x:Name="txtRecommendedRequirements" Style="{StaticResource InputTextBox}" Height="220" AcceptsReturn="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto"/>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </Grid>
                        </ScrollViewer>
                    </TabItem>
                </TabControl>

                <!-- Sticky Footer -->
                <Border Grid.Row="3" Background="#0A0A0C" BorderBrush="#1D1D22" BorderThickness="0,1,0,0" Padding="0,24,0,0" Margin="0,12,0,0">
                    <Grid>
                        <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="12"/><ColumnDefinition Width="240"/></Grid.ColumnDefinitions>
                        <Button Grid.Column="0" Content="Formu Temizle" Style="{StaticResource GhostButton}" Click="ResetButton_Click" HorizontalAlignment="Left" Width="160"/>
                        <Button Grid.Column="2" Content="Kaydı Oluştur" Style="{StaticResource PrimaryButton}" Click="SaveButton_Click" Height="54" FontSize="15"/>
                    </Grid>
                </Border>
            </Grid>
        </Grid>
    </Border>
</Window>
