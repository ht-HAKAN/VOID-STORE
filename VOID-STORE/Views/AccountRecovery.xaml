<Window x:Class="VOID_STORE.Views.AccountRecovery"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:VOID_STORE.Views"
        mc:Ignorable="d"
        Title="VOID STORE - Hesap Kurtarma" Height="700" Width="450"
        WindowStyle="None" AllowsTransparency="True" ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen" Background="#0A0A0C">

    <!-- Styles -->
    <Window.Resources>
        <!-- Alt kısımdaki tıklanabilir metinlerin genel stili -->
        <Style x:Key="LinkButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#AAAAAA"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Foreground" Value="White"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Ana buton özel stili -->
        <Style x:Key="MainButton" TargetType="Button">
            <Setter Property="Background" Value="#18181D"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#444444"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="0">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#222228"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Modern Başlık Çubuğu Buton Stili -->
        <Style x:Key="TitleBarButton" TargetType="Button">
            <Setter Property="Width" Value="42"/>
            <Setter Property="Height" Value="30"/>
            <Setter Property="Foreground" Value="#F5F7FA"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Surface" Background="Transparent" CornerRadius="0">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Surface" Property="Background" Value="#141418"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="30"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Özel Başlık Çubuğu -->
        <Grid Grid.Row="0" Background="Transparent" MouseLeftButtonDown="TitleBar_MouseLeftButtonDown" Panel.ZIndex="1">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Style="{StaticResource TitleBarButton}" Click="MinimizeButton_Click">
                    <TextBlock Text="&#xE921;" FontFamily="Segoe MDL2 Assets" FontSize="10" Foreground="White"/>
                </Button>
                <Button Click="CloseButton_Click">
                    <Button.Style>
                        <Style TargetType="Button" BasedOn="{StaticResource TitleBarButton}">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="Surface" Background="Transparent" CornerRadius="0">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="Surface" Property="Background" Value="#E81123"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </Button.Style>
                    <TextBlock Text="&#xE8BB;" FontFamily="Segoe MDL2 Assets" FontSize="10" Foreground="White"/>
                </Button>
            </StackPanel>
        </Grid>

        <!-- Sayfa İçeriği -->
        <Grid Grid.Row="1">
            
            <!-- Geri Dön Butonu -->
            <Button Content="🡠 Geri Dön" Style="{StaticResource LinkButton}" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="20,0,0,0" FontSize="14" Click="BackButton_Click">
                <Button.RenderTransform>
                    <TranslateTransform X="0" Y="0"/>
                </Button.RenderTransform>
                <Button.Triggers>
                    <EventTrigger RoutedEvent="MouseEnter">
                        <BeginStoryboard>
                            <Storyboard>
                                <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.X)" To="-5" Duration="0:0:0.2"/>
                            </Storyboard>
                        </BeginStoryboard>
                    </EventTrigger>
                    <EventTrigger RoutedEvent="MouseLeave">
                        <BeginStoryboard>
                            <Storyboard>
                                <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.X)" To="0" Duration="0:0:0.2"/>
                            </Storyboard>
                        </BeginStoryboard>
                    </EventTrigger>
                </Button.Triggers>
            </Button>

            <!-- Void Store Logosu -->
            <Image Source="../voidstoreimages/VOIDSTORE_NOBG_LOGO.png" Height="325" VerticalAlignment="Top" Margin="0,19,0,0" RenderOptions.BitmapScalingMode="HighQuality"/>

            <!-- Form Elemanları -->
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Top" Width="300" Margin="0,290,0,0">
                <TextBlock Text="GİRİŞ YAPAMIYORUM" Foreground="White" FontSize="20" FontWeight="Bold" HorizontalAlignment="Left" Margin="0,0,0,15"/>

                <TextBlock TextWrapping="Wrap" Foreground="#AAAAAA" FontSize="13" Margin="0,0,0,30" LineHeight="20">
                    Lütfen yaşadığınız sorunu seçin. Size yardımcı olabilmemiz için aşağıdaki seçeneklerden birine tıklayın.
                </TextBlock>

                <Button Content="Şifremi Unuttum" Style="{StaticResource MainButton}" Height="45" Margin="0,0,0,15" Click="ForgotPassword_Click"/>
                <Button Content="Kullanıcı Adımı Unuttum" Style="{StaticResource MainButton}" Height="45" Margin="0,0,0,15" Click="ForgotUsername_Click"/>
                <Button Content="E-posta Adresimi Hatırlamıyorum" Style="{StaticResource MainButton}" Height="45" Margin="0,0,0,0" Click="ForgotEmail_Click"/>
            </StackPanel>
        </Grid>
    </Grid>
</Window>
