<Window x:Class="VOID_STORE.Views.AdminEditGame"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="VOID STORE ADMIN"
        Height="980" Width="1640" MinHeight="900" MinWidth="1460"
        WindowStyle="None" AllowsTransparency="True" ResizeMode="CanResize"
        WindowStartupLocation="CenterOwner" Background="Transparent">
    <Window.Resources>
        <Style x:Key="TitleBarButton" TargetType="Button">
            <Setter Property="Width" Value="42"/><Setter Property="Height" Value="30"/><Setter Property="Foreground" Value="#F5F7FA"/><Setter Property="Background" Value="Transparent"/><Setter Property="BorderThickness" Value="0"/><Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template"><Setter.Value><ControlTemplate TargetType="Button"><Border x:Name="Surface" Background="Transparent" CornerRadius="8"><ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/></Border><ControlTemplate.Triggers><Trigger Property="IsMouseOver" Value="True"><Setter TargetName="Surface" Property="Background" Value="#141418"/></Trigger></ControlTemplate.Triggers></ControlTemplate></Setter.Value></Setter>
        </Style>
        <Style x:Key="GhostButton" TargetType="Button">
            <Setter Property="Height" Value="42"/><Setter Property="Padding" Value="18,0"/><Setter Property="Background" Value="#111114"/><Setter Property="Foreground" Value="White"/><Setter Property="BorderBrush" Value="#1C1C22"/><Setter Property="BorderThickness" Value="1"/><Setter Property="FontSize" Value="13"/><Setter Property="FontWeight" Value="SemiBold"/><Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template"><Setter.Value><ControlTemplate TargetType="Button"><Border x:Name="Surface" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="12" RenderTransformOrigin="0.5,0.5"><Border.RenderTransform><ScaleTransform ScaleX="1" ScaleY="1"/></Border.RenderTransform><ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/></Border><ControlTemplate.Triggers><Trigger Property="IsMouseOver" Value="True"><Trigger.EnterActions><BeginStoryboard><Storyboard><DoubleAnimation Storyboard.TargetName="Surface" Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)" To="1.02" Duration="0:0:0.1"/><DoubleAnimation Storyboard.TargetName="Surface" Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)" To="1.02" Duration="0:0:0.1"/></Storyboard></BeginStoryboard></Trigger.EnterActions><Trigger.ExitActions><BeginStoryboard><Storyboard><DoubleAnimation Storyboard.TargetName="Surface" Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)" To="1" Duration="0:0:0.1"/><DoubleAnimation Storyboard.TargetName="Surface" Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)" To="1" Duration="0:0:0.1"/></Storyboard></BeginStoryboard></Trigger.ExitActions></Trigger></ControlTemplate.Triggers></ControlTemplate></Setter.Value></Setter>
            <Style.Triggers><Trigger Property="IsMouseOver" Value="True"><Setter Property="Background" Value="#17171B"/><Setter Property="BorderBrush" Value="#282830"/></Trigger></Style.Triggers>
        </Style>
        <Style x:Key="PrimaryButton" TargetType="Button" BasedOn="{StaticResource GhostButton}">
            <Setter Property="Background" Value="#FFFFFF"/><Setter Property="Foreground" Value="#0A0A0C"/><Setter Property="BorderBrush" Value="#FFFFFF"/>
            <Style.Triggers><Trigger Property="IsMouseOver" Value="True"><Setter Property="Background" Value="#EBEDF0"/><Setter Property="BorderBrush" Value="#EBEDF0"/></Trigger></Style.Triggers>
        </Style>
        <Style x:Key="InputTextBox" TargetType="TextBox">
            <Setter Property="Foreground" Value="White"/><Setter Property="Background" Value="#0D0D10"/><Setter Property="BorderBrush" Value="#1D1D22"/><Setter Property="BorderThickness" Value="1"/><Setter Property="FontSize" Value="14"/><Setter Property="Padding" Value="14,12"/>
            <Setter Property="Template"><Setter.Value><ControlTemplate TargetType="TextBox"><Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="12"><ScrollViewer x:Name="PART_ContentHost"/></Border></ControlTemplate></Setter.Value></Setter>
        </Style>
        <Style x:Key="InputComboBox" TargetType="ComboBox">
            <Setter Property="Foreground" Value="White"/><Setter Property="Background" Value="#0D0D10"/><Setter Property="BorderBrush" Value="#1D1D22"/><Setter Property="BorderThickness" Value="1"/><Setter Property="FontSize" Value="14"/><Setter Property="Padding" Value="14,10"/><Setter Property="Height" Value="48"/>
        </Style>
        <Style TargetType="ComboBoxItem">
            <Setter Property="Foreground" Value="White"/><Setter Property="Background" Value="#111114"/><Setter Property="Padding" Value="12,8"/><Setter Property="FontSize" Value="13"/>
            <Style.Triggers><Trigger Property="IsHighlighted" Value="True"><Setter Property="Background" Value="#1A1A20"/></Trigger><Trigger Property="IsSelected" Value="True"><Setter Property="Background" Value="#FFFFFF"/><Setter Property="Foreground" Value="#09090B"/></Trigger></Style.Triggers>
        </Style>
        <Style x:Key="CategoryListBox" TargetType="ListBox">
            <Setter Property="Background" Value="Transparent"/><Setter Property="BorderThickness" Value="0"/><Setter Property="HorizontalContentAlignment" Value="Stretch"/><Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Disabled"/><Setter Property="ScrollViewer.VerticalScrollBarVisibility" Value="Disabled"/>
            <Setter Property="Template"><Setter.Value><ControlTemplate TargetType="ListBox"><ItemsPresenter/></ControlTemplate></Setter.Value></Setter>
        </Style>
        <Style x:Key="CategoryListItemStyle" TargetType="ListBoxItem">
            <Setter Property="Foreground" Value="#F2F4F7"/><Setter Property="Background" Value="#0D0D10"/><Setter Property="BorderBrush" Value="#1D1D22"/><Setter Property="BorderThickness" Value="1"/><Setter Property="Padding" Value="16,12"/><Setter Property="Margin" Value="0,0,12,12"/><Setter Property="FontSize" Value="13"/><Setter Property="FontWeight" Value="SemiBold"/><Setter Property="HorizontalContentAlignment" Value="Center"/><Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template"><Setter.Value><ControlTemplate TargetType="ListBoxItem"><Border x:Name="Surface" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="12" Padding="{TemplateBinding Padding}"><ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/></Border><ControlTemplate.Triggers><Trigger Property="IsMouseOver" Value="True"><Setter TargetName="Surface" Property="Background" Value="#141418"/><Setter TargetName="Surface" Property="BorderBrush" Value="#2B2B32"/></Trigger><Trigger Property="IsSelected" Value="True"><Setter TargetName="Surface" Property="Background" Value="#FFFFFF"/><Setter TargetName="Surface" Property="BorderBrush" Value="#FFFFFF"/><Setter Property="Foreground" Value="#0A0A0C"/></Trigger></ControlTemplate.Triggers></ControlTemplate></Setter.Value></Setter>
        </Style>
        <Style x:Key="SectionCard" TargetType="Border"><Setter Property="Background" Value="#0F0F12"/><Setter Property="BorderBrush" Value="#19191E"/><Setter Property="BorderThickness" Value="1"/><Setter Property="CornerRadius" Value="16"/><Setter Property="Padding" Value="28"/></Style>
        <Style x:Key="PlatformToggleButton" TargetType="ToggleButton">
            <Setter Property="Background" Value="#0D0D10"/><Setter Property="Foreground" Value="#F2F4F7"/><Setter Property="BorderBrush" Value="#1D1D22"/><Setter Property="BorderThickness" Value="1"/><Setter Property="FontSize" Value="13"/><Setter Property="FontWeight" Value="SemiBold"/><Setter Property="Cursor" Value="Hand"/><Setter Property="Padding" Value="16,12"/><Setter Property="Margin" Value="0,0,12,12"/>
            <Setter Property="Template"><Setter.Value><ControlTemplate TargetType="ToggleButton"><Border x:Name="Surface" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="12" Padding="{TemplateBinding Padding}"><ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/></Border><ControlTemplate.Triggers><Trigger Property="IsMouseOver" Value="True"><Setter TargetName="Surface" Property="Background" Value="#141418"/><Setter TargetName="Surface" Property="BorderBrush" Value="#2B2B32"/></Trigger><Trigger Property="IsChecked" Value="True"><Setter TargetName="Surface" Property="Background" Value="#FFFFFF"/><Setter TargetName="Surface" Property="BorderBrush" Value="#FFFFFF"/><Setter Property="Foreground" Value="#0A0A0C"/></Trigger></ControlTemplate.Triggers></ControlTemplate></Setter.Value></Setter>
        </Style>
        <Style x:Key="GameListItemStyle" TargetType="ListBoxItem">
            <Setter Property="Background" Value="#0C0C10"/><Setter Property="BorderBrush" Value="#17171C"/><Setter Property="BorderThickness" Value="1"/><Setter Property="Padding" Value="16"/><Setter Property="Margin" Value="0,0,0,12"/><Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Template"><Setter.Value><ControlTemplate TargetType="ListBoxItem"><Border x:Name="Surface" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="16" Padding="{TemplateBinding Padding}"><ContentPresenter/></Border><ControlTemplate.Triggers><Trigger Property="IsMouseOver" Value="True"><Setter TargetName="Surface" Property="Background" Value="#111116"/><Setter TargetName="Surface" Property="BorderBrush" Value="#23232B"/></Trigger><Trigger Property="IsSelected" Value="True"><Setter TargetName="Surface" Property="Background" Value="#15151B"/><Setter TargetName="Surface" Property="BorderBrush" Value="#FFFFFF"/></Trigger></ControlTemplate.Triggers></ControlTemplate></Setter.Value></Setter>
        </Style>
        <Style TargetType="RepeatButton"><Setter Property="Focusable" Value="False"/><Setter Property="Template"><Setter.Value><ControlTemplate TargetType="RepeatButton"><Border Background="Transparent"/></ControlTemplate></Setter.Value></Setter></Style>
        <Style TargetType="Thumb"><Setter Property="Template"><Setter.Value><ControlTemplate TargetType="Thumb"><Border Background="#1F2026" CornerRadius="6"/></ControlTemplate></Setter.Value></Setter></Style>
        <Style TargetType="ScrollBar"><Setter Property="Background" Value="#0A0A0D"/><Setter Property="Width" Value="12"/><Setter Property="Template"><Setter.Value><ControlTemplate TargetType="ScrollBar"><Border Background="#0A0A0D" CornerRadius="6" Padding="2"><Track x:Name="PART_Track" IsDirectionReversed="True"><Track.DecreaseRepeatButton><RepeatButton/></Track.DecreaseRepeatButton><Track.Thumb><Thumb/></Track.Thumb><Track.IncreaseRepeatButton><RepeatButton/></Track.IncreaseRepeatButton></Track></Border></ControlTemplate></Setter.Value></Setter><Style.Triggers><Trigger Property="Orientation" Value="Horizontal"><Setter Property="Height" Value="12"/><Setter Property="Width" Value="Auto"/></Trigger></Style.Triggers></Style>
        <Style TargetType="TabControl">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabControl">
                        <Grid KeyboardNavigation.TabNavigation="Local">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <TabPanel Grid.Row="0" IsItemsHost="True" Margin="0,0,0,20"/>
                            <Border Grid.Row="1" Background="Transparent">
                                <ContentPresenter x:Name="PART_SelectedContentHost" ContentSource="SelectedContent"/>
                            </Border>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="TabItem">
            <Setter Property="Background" Value="#0D0D10"/>
            <Setter Property="Foreground" Value="#8F98A5"/>
            <Setter Property="BorderBrush" Value="#1D1D22"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="24,12"/>
            <Setter Property="MinWidth" Value="150"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Margin" Value="0,0,10,0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Border x:Name="Surface" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" Margin="0" Padding="{TemplateBinding Padding}" CornerRadius="12">
                            <ContentPresenter x:Name="Content" ContentSource="Header" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Surface" Property="Background" Value="#141418"/>
                                <Setter TargetName="Surface" Property="BorderBrush" Value="#2B2B32"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Surface" Property="Background" Value="#FFFFFF"/>
                                <Setter TargetName="Surface" Property="BorderBrush" Value="#FFFFFF"/>
                                <Setter Property="Foreground" Value="#0A0A0C"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.3"/>
                            </Trigger>
                            <DataTrigger Binding="{Binding RelativeSource={RelativeSource Self}, Path=Tag}" Value="Valid">
                                <Setter TargetName="Surface" Property="BorderBrush" Value="#2ECC71"/>
                                <Setter TargetName="Surface" Property="Background" Value="#0A2215"/>
                                <Setter Property="Foreground" Value="#2ECC71"/>
                            </DataTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="ModernSwitch" TargetType="ToggleButton">
            <Setter Property="Width" Value="54"/>
            <Setter Property="Height" Value="28"/>
            <Setter Property="Background" Value="#17171B"/>
            <Setter Property="BorderBrush" Value="#282830"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border x:Name="Border" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}">
                            <Grid>
                                <Border x:Name="Dot" HorizontalAlignment="Left" Width="20" Height="20" Background="#3F444D" Margin="3,0,0,0">
                                    <Border.RenderTransform>
                                        <TranslateTransform X="0"/>
                                    </Border.RenderTransform>
                                </Border>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="#FFFFFF"/>
                                <Setter TargetName="Dot" Property="Background" Value="#0A0A0C"/>
                                <Trigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="Dot" Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.X)" To="26" Duration="0:0:0.15"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.EnterActions>
                                <Trigger.ExitActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="Dot" Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.X)" To="0" Duration="0:0:0.15"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.ExitActions>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Storyboard x:Key="FadeInAnimation">
            <DoubleAnimation Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="0:0:0.3"/>
        </Storyboard>
    </Window.Resources>
    <Border Background="#09090B" BorderBrush="#17171B" BorderThickness="1" CornerRadius="24">
        <Grid>
            <Grid.RowDefinitions><RowDefinition Height="34"/><RowDefinition Height="*"/></Grid.RowDefinitions>
            <Grid Grid.Row="0" Margin="12,0,10,0" MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                <TextBlock Text="OYUN GÜNCELLE" Foreground="#6E7682" FontSize="11" FontWeight="SemiBold" VerticalAlignment="Center" Margin="6,0,0,0"/>
                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <Button Style="{StaticResource TitleBarButton}" Click="MinimizeButton_Click"><TextBlock Text="&#xE921;" FontFamily="Segoe MDL2 Assets" FontSize="10"/></Button>
                    <Button Style="{StaticResource TitleBarButton}" Click="ToggleWindowStateButton_Click"><TextBlock Text="&#xE922;" FontFamily="Segoe MDL2 Assets" FontSize="10"/></Button>
                    <Button Click="CloseButton_Click"><Button.Style><Style TargetType="Button" BasedOn="{StaticResource TitleBarButton}"><Setter Property="Template"><Setter.Value><ControlTemplate TargetType="Button"><Border x:Name="Surface" Background="Transparent" CornerRadius="8"><ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/></Border><ControlTemplate.Triggers><Trigger Property="IsMouseOver" Value="True"><Setter TargetName="Surface" Property="Background" Value="#E81123"/></Trigger></ControlTemplate.Triggers></ControlTemplate></Setter.Value></Setter></Style></Button.Style><TextBlock Text="&#xE8BB;" FontFamily="Segoe MDL2 Assets" FontSize="10"/></Button>
                </StackPanel>
            </Grid>
            <Grid Grid.Row="1" Margin="28,24,28,28">
                <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="24"/><RowDefinition Height="*"/></Grid.RowDefinitions>
                <Grid>
                    <Grid.ColumnDefinitions><ColumnDefinition Width="Auto"/><ColumnDefinition Width="24"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                    <Button Grid.Column="0" Width="132" Content="← Geri Dön" Style="{StaticResource GhostButton}" Click="BackButton_Click"/>
                    <StackPanel Grid.Column="2"><TextBlock Text="Oyun Güncelle" Foreground="White" FontSize="34" FontWeight="Bold"/><TextBlock Text="Listelenen oyunları seçin ve güncellenen sürümü onaya gönderin." Foreground="#9AA4B1" FontSize="13" Margin="0,10,0,0"/></StackPanel>
                </Grid>
                <Grid Grid.Row="2">
                    <Grid.ColumnDefinitions><ColumnDefinition Width="400"/><ColumnDefinition Width="24"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                    <Border Grid.Column="0" Style="{StaticResource SectionCard}">
                        <Grid><Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="18"/><RowDefinition Height="Auto"/><RowDefinition Height="18"/><RowDefinition Height="*"/></Grid.RowDefinitions>
                            <StackPanel><TextBlock Text="Oyun Listesi" Foreground="White" FontSize="22" FontWeight="SemiBold"/><TextBlock Text="Bu listede yalnızca yayındaki oyunlar yer alır" Foreground="#8F98A5" FontSize="13" Margin="0,8,0,0"/></StackPanel>
                            <TextBox x:Name="txtSearch" Grid.Row="2" Style="{StaticResource InputTextBox}" TextChanged="SearchTextBox_TextChanged"/>
                            <ListBox x:Name="lstGames" Grid.Row="4" Background="Transparent" BorderThickness="0" ItemContainerStyle="{StaticResource GameListItemStyle}" SelectionChanged="GamesList_SelectionChanged" ScrollViewer.HorizontalScrollBarVisibility="Disabled" ScrollViewer.VerticalScrollBarVisibility="Auto" Margin="0,0,0,0" Padding="0,0,20,0">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <Grid>
                                            <Grid.ColumnDefinitions><ColumnDefinition Width="84"/><ColumnDefinition Width="14"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                            <Border Background="#111115" CornerRadius="0" Width="84" Height="112">
                                                <Grid>
                                                    <Image x:Name="PreviewImage" Source="{Binding CoverPreview}" Stretch="UniformToFill"/>
                                                    <TextBlock x:Name="PreviewPlaceholder" Text="VOID STORE" Foreground="#4A515C" FontSize="10" FontWeight="SemiBold" HorizontalAlignment="Center" VerticalAlignment="Center" Visibility="Collapsed"/>
                                                </Grid>
                                            </Border>
                                            <StackPanel Grid.Column="2" VerticalAlignment="Center">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Text="{Binding Title}" Foreground="White" FontSize="16" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" VerticalAlignment="Center"/>
                                                    <Border x:Name="DraftBadge" Grid.Column="1" Background="#182232" CornerRadius="0" Padding="8,4" Margin="8,0,0,0" Visibility="Collapsed" VerticalAlignment="Center">
                                                        <TextBlock Text="Güncelleme Var" Foreground="#63A7FF" FontSize="10" FontWeight="SemiBold"/>
                                                    </Border>
                                                </Grid>
                                                <TextBlock Text="{Binding Publisher}" Foreground="#8F98A5" FontSize="12" Margin="0,8,0,0"/>
                                                <TextBlock x:Name="StatusTextDisplay" Text="{Binding StatusText}" Foreground="#D7DDE5" FontSize="11" Margin="0,8,0,0"/>
                                            </StackPanel>
                                        </Grid>
                                        <DataTemplate.Triggers>
                                            <DataTrigger Binding="{Binding StatusText}" Value="Yayında">
                                                <Setter TargetName="StatusTextDisplay" Property="Foreground" Value="#2ECC71"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding StatusText}" Value="Sürüm Bekliyor">
                                                <Setter TargetName="StatusTextDisplay" Property="Foreground" Value="#63A7FF"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding HasPendingDraft}" Value="True">
                                                <Setter TargetName="DraftBadge" Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding CoverPreview}" Value="{x:Null}">
                                                <Setter TargetName="PreviewPlaceholder" Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding CoverPreview}" Value="{x:Null}">
                                                <Setter TargetName="PreviewImage" Property="Visibility" Value="Collapsed"/>
                                            </DataTrigger>
                                        </DataTemplate.Triggers>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </Grid>
                    </Border>
                    <Grid Grid.Column="2">
                        <Grid x:Name="EditorScroll" Visibility="Collapsed" Opacity="0">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <!-- Editor Header -->
                            <Border Grid.Row="0" Background="#0D0D10" BorderBrush="#1D1D22" BorderThickness="1" Padding="20,16" Margin="0,0,0,20">
                                <DockPanel LastChildFill="False">
                                    <StackPanel>
                                        <TextBlock Text="Oyun Bilgilerini Düzenle" Foreground="White" FontSize="18" FontWeight="SemiBold"/>
                                        <TextBlock x:Name="txtDraftHint" Text="Seçilen oyunun mevcut bilgilerini güncelleyin." Foreground="#8F98A5" FontSize="12" Margin="0,4,0,0"/>
                                    </StackPanel>
                                    <Border DockPanel.Dock="Right" Background="#182232" CornerRadius="0" Padding="12,6" VerticalAlignment="Center">
                                        <TextBlock x:Name="txtDraftStatus" Text="Yükleniyor" Foreground="#63A7FF" FontSize="11" FontWeight="SemiBold"/>
                                    </Border>
                                </DockPanel>
                            </Border>

                            <!-- Editor Content (Tabs) -->
                            <TabControl x:Name="AdminTabControl" Grid.Row="1">
                                <!-- Tab 1: Genel Bilgiler -->
                                <TabItem x:Name="TabItemGenel" Header="GENEL BİLGİLER">
                                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                                        <Border Style="{StaticResource SectionCard}">
                                            <StackPanel>
                                                <Grid Margin="0,0,0,20">
                                                    <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="20"/><ColumnDefinition Width="200"/></Grid.ColumnDefinitions>
                                                    <StackPanel Grid.Column="0">
                                                        <TextBlock Text="Oyun Adı" Foreground="#D6D9DE" FontSize="12" FontWeight="SemiBold" Margin="0,0,0,8"/>
                                                        <TextBox x:Name="txtTitle" Style="{StaticResource InputTextBox}" TextChanged="Input_Changed"/>
                                                        <TextBlock x:Name="txtTitleError" Text="* Oyun adı boş bırakılamaz" Foreground="#FF5555" FontSize="10" Margin="4,4,0,0" Visibility="Collapsed"/>
                                                    </StackPanel>
                                                    <StackPanel Grid.Column="2">
                                                        <Grid Margin="0,0,0,8" VerticalAlignment="Center">
                                                            <TextBlock Text="Fiyat" Foreground="#D6D9DE" FontSize="12" FontWeight="SemiBold" Margin="0" VerticalAlignment="Center"/>
                                                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                                                                <TextBlock x:Name="lblIsFree" Text="Oynaması Ücretsiz" FontSize="11" VerticalAlignment="Center" Margin="0,0,8,0">
                                                                    <TextBlock.Style>
                                                                        <Style TargetType="TextBlock">
                                                                            <Setter Property="Foreground" Value="#7F8690"/>
                                                                            <Style.Triggers>
                                                                                <DataTrigger Binding="{Binding IsChecked, ElementName=tglIsFree}" Value="True">
                                                                                    <Setter Property="Foreground" Value="#2ECC71"/>
                                                                                </DataTrigger>
                                                                            </Style.Triggers>
                                                                        </Style>
                                                                    </TextBlock.Style>
                                                                </TextBlock>
                                                                <ToggleButton x:Name="tglIsFree" Style="{StaticResource ModernSwitch}" VerticalAlignment="Center" Click="tglIsFree_Click"/>
                                                            </StackPanel>
                                                        </Grid>
                                                        <Grid x:Name="gridPriceInput">
                                                            <Grid.Style>
                                                                <Style TargetType="Grid">
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding IsChecked, ElementName=tglIsFree}" Value="True">
                                                                            <Setter Property="Opacity" Value="0.4"/>
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </Grid.Style>
                                                            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="8"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                                            <TextBox x:Name="txtPrice" Style="{StaticResource InputTextBox}" PreviewTextInput="PriceTextBox_PreviewTextInput" LostFocus="PriceTextBox_LostFocus" TextChanged="Input_Changed"/>
                                                            <Border Grid.Column="2" Background="#111114" BorderBrush="#1D1D22" BorderThickness="1" Padding="12,0" Height="44" CornerRadius="12"><TextBlock Text="&#x20BA;" Foreground="White" FontSize="16" FontWeight="SemiBold" VerticalAlignment="Center"/></Border>
                                                        </Grid>
                                                        <TextBlock x:Name="txtPriceError" Text="* Geçerli bir fiyat girin" Foreground="#FF5555" FontSize="10" Margin="4,4,0,0" Visibility="Collapsed"/>
                                                        <TextBlock x:Name="txtFreeWarning" Text="Oynaması ücretsiz oyunlara fiyat bilgisi girilemez" Foreground="#7F8690" FontSize="10" Margin="4,4,0,0" Visibility="Collapsed">
                                                            <TextBlock.Style>
                                                                <Style TargetType="TextBlock">
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding IsChecked, ElementName=tglIsFree}" Value="True">
                                                                            <Setter Property="Visibility" Value="Visible"/>
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </TextBlock.Style>
                                                        </TextBlock>
                                                    </StackPanel>
                                                </Grid>

                                                <StackPanel Margin="0,0,0,20">
                                                    <TextBlock Text="Kategori" Foreground="#D6D9DE" FontSize="12" FontWeight="SemiBold" Margin="0,0,0,8"/>
                                                    <ListBox x:Name="lstCategory" Style="{StaticResource CategoryListBox}" ItemContainerStyle="{StaticResource CategoryListItemStyle}" SelectionMode="Single" SelectionChanged="Input_Changed"><ListBox.ItemsPanel><ItemsPanelTemplate><WrapPanel/></ItemsPanelTemplate></ListBox.ItemsPanel></ListBox>
                                                    <TextBlock x:Name="txtCategoryError" Text="* Lütfen bir kategori seçin" Foreground="#FF5555" FontSize="10" Margin="4,4,0,0" Visibility="Collapsed"/>
                                                </StackPanel>

                                                <Grid Margin="0,0,0,20">
                                                    <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="20"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                                    <StackPanel Grid.Column="0">
                                                        <TextBlock Text="Yapımcı" Foreground="#D6D9DE" FontSize="12" FontWeight="SemiBold" Margin="0,0,0,8"/>
                                                        <TextBox x:Name="txtDeveloper" Style="{StaticResource InputTextBox}" TextChanged="Input_Changed"/>
                                                        <TextBlock x:Name="txtDeveloperError" Text="* Yapımcı adı gerekli" Foreground="#FF5555" FontSize="10" Margin="4,4,0,0" Visibility="Collapsed"/>
                                                    </StackPanel>
                                                    <StackPanel Grid.Column="2">
                                                        <TextBlock Text="Yayıncı" Foreground="#D6D9DE" FontSize="12" FontWeight="SemiBold" Margin="0,0,0,8"/>
                                                        <TextBox x:Name="txtPublisher" Style="{StaticResource InputTextBox}" TextChanged="Input_Changed"/>
                                                        <TextBlock x:Name="txtPublisherError" Text="* Yayıncı adı gerekli" Foreground="#FF5555" FontSize="10" Margin="4,4,0,0" Visibility="Collapsed"/>
                                                    </StackPanel>
                                                </Grid>

                                                <StackPanel Margin="0,0,0,20">
                                                    <TextBlock Text="Çıkış Tarihi" Foreground="#D6D9DE" FontSize="12" FontWeight="SemiBold" Margin="0,0,0,8"/>
                                                    <TextBox x:Name="txtReleaseDate" Style="{StaticResource InputTextBox}" PreviewTextInput="ReleaseDateTextBox_PreviewTextInput" GotFocus="ReleaseDateTextBox_GotFocus" LostFocus="ReleaseDateTextBox_LostFocus" TextChanged="Input_Changed"/>
                                                    <TextBlock x:Name="txtReleaseDateError" Text="* Geçerli bir tarih girin" Foreground="#FF5555" FontSize="10" Margin="4,4,0,0" Visibility="Collapsed"/>
                                                </StackPanel>

                                                <!-- İndirim Yönetimi -->
                                                <Border x:Name="borderDiscount" BorderBrush="#1D1D22" BorderThickness="0,1,0,0" Margin="0,0,0,20" Padding="0,20,0,0">
                                                    <StackPanel>
                                                        <TextBlock Text="İNDİRİM YÖNETİMİ" Foreground="White" FontSize="13" FontWeight="Bold" Margin="0,0,0,14"/>
                                                        <Grid>
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="130"/>
                                                                <ColumnDefinition Width="20"/>
                                                                <ColumnDefinition Width="*"/>
                                                                <ColumnDefinition Width="20"/>
                                                                <ColumnDefinition Width="*"/>
                                                            </Grid.ColumnDefinitions>
                                                            
                                                            <StackPanel Grid.Column="0">
                                                                <TextBlock Text="İndirim Oranı (%)" Foreground="#D6D9DE" FontSize="11" FontWeight="SemiBold" Margin="0,0,0,6"/>
                                                                <TextBox x:Name="txtDiscountRate" Style="{StaticResource InputTextBox}" Text="0" MaxLength="3" PreviewTextInput="OnlyNumbers_PreviewTextInput" TextChanged="Input_Changed"/>
                                                            </StackPanel>

                                                            <StackPanel Grid.Column="2">
                                                                <TextBlock Text="Başlangıç Tarihi" Foreground="#D6D9DE" FontSize="11" FontWeight="SemiBold" Margin="0,0,0,6"/>
                                                                <TextBox x:Name="txtDiscountStart" Style="{StaticResource InputTextBox}" PreviewTextInput="ReleaseDateTextBox_PreviewTextInput" TextChanged="Input_Changed"/>
                                                            </StackPanel>

                                                            <StackPanel Grid.Column="4">
                                                                <TextBlock Text="Bitiş Tarihi" Foreground="#D6D9DE" FontSize="11" FontWeight="SemiBold" Margin="0,0,0,6"/>
                                                                <TextBox x:Name="txtDiscountEnd" Style="{StaticResource InputTextBox}" PreviewTextInput="ReleaseDateTextBox_PreviewTextInput" TextChanged="Input_Changed"/>
                                                            </StackPanel>
                                                        </Grid>
                                                    </StackPanel>
                                                </Border>

                                                <StackPanel>
                                                    <TextBlock Text="Açıklama" Foreground="#D6D9DE" FontSize="12" FontWeight="SemiBold" Margin="0,0,0,8"/>
                                                    <TextBox x:Name="txtDescription" Style="{StaticResource InputTextBox}" Height="240" AcceptsReturn="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto"/>
                                                </StackPanel>
                                            </StackPanel>
                                        </Border>
                                    </ScrollViewer>
                                </TabItem>

                                <!-- Tab 2: Medya Yönetimi -->
                                <TabItem x:Name="TabItemMedya" Header="MEDYA YÖNETİMİ" IsEnabled="False">
                                    <Grid>
                                        <Grid.ColumnDefinitions><ColumnDefinition Width="300"/><ColumnDefinition Width="20"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0">
                                            <Border Background="#0D0D10" BorderBrush="#1D1D22" BorderThickness="1" MinHeight="400" Padding="12">
                                                <Grid>
                                                    <Image x:Name="imgCoverPreview" Stretch="UniformToFill" Visibility="Collapsed"/>
                                                    <StackPanel x:Name="CoverPlaceholder" VerticalAlignment="Center">
                                                        <TextBlock Text="&#xE722;" FontFamily="Segoe MDL2 Assets" FontSize="42" Foreground="#1C1C22" HorizontalAlignment="Center"/>
                                                        <TextBlock Text="Kapak Görseli" Foreground="White" FontSize="16" FontWeight="SemiBold" HorizontalAlignment="Center" Margin="0,12,0,0"/>
                                                    </StackPanel>
                                                </Grid>
                                            </Border>
                                            <Button Content="Kapağı Değiştir" Style="{StaticResource GhostButton}" Margin="0,12,0,0" Click="SelectCoverButton_Click"/>
                                            <Border Background="#111115" Margin="0,12,0,0" Padding="12" BorderThickness="1" BorderBrush="#1C1C22">
                                                <TextBlock x:Name="txtCoverStatus" Text="Mevcut Kapak" Foreground="#8F98A5" FontSize="11" TextWrapping="Wrap" HorizontalAlignment="Center"/>
                                            </Border>
                                        </StackPanel>

                                        <StackPanel Grid.Column="2">
                                            <Border Style="{StaticResource SectionCard}" Padding="20">
                                                <StackPanel>
                                                    <Grid Margin="0,0,0,16">
                                                        <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="10"/><ColumnDefinition Width="*"/><ColumnDefinition Width="10"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                                        <Button Grid.Column="0" Content="Yeni Görsel" Style="{StaticResource GhostButton}" Click="SelectGalleryButton_Click"/>
                                                        <Button Grid.Column="2" Content="Fragman Seç" Style="{StaticResource GhostButton}" Click="SelectTrailerButton_Click"/>
                                                        <Button Grid.Column="4" Content="Kaldır" Style="{StaticResource GhostButton}" Click="RemoveGalleryButton_Click"/>
                                                    </Grid>

                                                    <Grid Margin="0,0,0,16">
                                                        <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="10"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                                        <Border Grid.Column="0" Background="#0D0D10" Padding="12" BorderThickness="1" BorderBrush="#1C1C22">
                                                            <StackPanel><TextBlock Text="Galeri" Foreground="#8F98A5" FontSize="11"/><TextBlock x:Name="txtGalleryStatus" Text="0 / 8" Foreground="White" FontSize="14" FontWeight="SemiBold" Margin="0,4,0,0"/></StackPanel>
                                                        </Border>
                                                        <Border Grid.Column="2" Background="#0D0D10" Padding="12" BorderThickness="1" BorderBrush="#1C1C22">
                                                            <StackPanel><TextBlock Text="Fragman" Foreground="#8F98A5" FontSize="11"/><TextBlock x:Name="txtTrailerStatus" Text="Seçilmedi" Foreground="White" FontSize="14" FontWeight="SemiBold" Margin="0,4,0,0" TextTrimming="CharacterEllipsis"/></StackPanel>
                                                        </Border>
                                                    </Grid>

                                                    <TextBlock Text="Galeri Dosyaları" Foreground="#D6D9DE" FontSize="12" FontWeight="SemiBold" Margin="0,0,0,8"/>
                                                    <ListBox x:Name="lstGalleryFiles" Background="#0D0D10" BorderThickness="1" BorderBrush="#1C1C22" Height="180" Foreground="#D7DDE5" FontSize="12"/>
                                                </StackPanel>
                                            </Border>
                                        </StackPanel>
                                    </Grid>
                                </TabItem>

                                <!-- Tab 3: Sistem & Platform -->
                                <TabItem x:Name="TabItemSistem" Header="SİSTEM &amp; PLATFORM" IsEnabled="False">
                                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                                        <StackPanel>
                                            <Border Style="{StaticResource SectionCard}">
                                                <StackPanel>
                                                    <Grid Margin="0,0,0,20">
                                                        <Grid.ColumnDefinitions><ColumnDefinition Width="Auto"/><ColumnDefinition Width="30"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                                        <StackPanel Grid.Column="0">
                                                            <TextBlock Text="Platformlar" Foreground="#D6D9DE" FontSize="12" FontWeight="SemiBold" Margin="0,0,0,8"/>
                                                            <WrapPanel><ToggleButton x:Name="tglWindows" Content="Windows" MinWidth="80" Margin="0,0,8,8" Style="{StaticResource PlatformToggleButton}"/><ToggleButton x:Name="tglMacOs" Content="macOS" MinWidth="80" Margin="0,0,8,8" Style="{StaticResource PlatformToggleButton}"/><ToggleButton x:Name="tglLinux" Content="Linux" MinWidth="80" Margin="0,0,8,8" Style="{StaticResource PlatformToggleButton}"/></WrapPanel>
                                                        </StackPanel>
                                                        <StackPanel Grid.Column="2">
                                                            <TextBlock Text="Özellikler" Foreground="#D6D9DE" FontSize="12" FontWeight="SemiBold" Margin="0,0,0,8"/>
                                                            <ListBox x:Name="lstFeatures" Style="{StaticResource CategoryListBox}" ItemContainerStyle="{StaticResource CategoryListItemStyle}" SelectionMode="Multiple"><ListBox.ItemsPanel><ItemsPanelTemplate><WrapPanel/></ItemsPanelTemplate></ListBox.ItemsPanel></ListBox>
                                                        </StackPanel>
                                                    </Grid>

                                                    <Grid Margin="0,0,0,20">
                                                        <Grid.ColumnDefinitions><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                                        <StackPanel Grid.Column="0"><TextBlock Text="Desteklenen Diller" Foreground="#D6D9DE" FontSize="12" FontWeight="SemiBold" Margin="0,0,0,8"/><TextBox x:Name="txtSupportedLanguages" Style="{StaticResource InputTextBox}" Height="Auto" MinHeight="44" TextWrapping="Wrap" Padding="12,10"/></StackPanel>
                                                    </Grid>

                                                    <Grid>
                                                        <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="20"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                                        <StackPanel Grid.Column="0"><TextBlock Text="Minimum Gereksinimler" Foreground="#D6D9DE" FontSize="12" FontWeight="SemiBold" Margin="0,0,0,8"/><TextBox x:Name="txtMinimumRequirements" Style="{StaticResource InputTextBox}" Height="200" AcceptsReturn="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto"/></StackPanel>
                                                        <StackPanel Grid.Column="2"><TextBlock Text="Önerilen Gereksinimler" Foreground="#D6D9DE" FontSize="12" FontWeight="SemiBold" Margin="0,0,0,8"/><TextBox x:Name="txtRecommendedRequirements" Style="{StaticResource InputTextBox}" Height="200" AcceptsReturn="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto"/></StackPanel>
                                                    </Grid>
                                                </StackPanel>
                                            </Border>
                                        </StackPanel>
                                    </ScrollViewer>
                                </TabItem>
                            </TabControl>

                            <!-- Editor Footer -->
                            <Border Grid.Row="2" Background="#0A0A0C" BorderBrush="#1D1D22" BorderThickness="0,1,0,0" Padding="0,20,0,0" Margin="0,12,0,0">
                                <Grid>
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="12"/><ColumnDefinition Width="Auto"/><ColumnDefinition Width="12"/><ColumnDefinition Width="220"/></Grid.ColumnDefinitions>
                                    <Button Grid.Column="0" Content="Değişiklikleri Geri Al" Style="{StaticResource GhostButton}" Click="ResetButton_Click" HorizontalAlignment="Left" Width="180"/>
                                    <Button Grid.Column="4" Content="Değişiklikleri Kaydet" Style="{StaticResource PrimaryButton}" Click="SaveButton_Click" Height="50" FontSize="14"/>
                                </Grid>
                            </Border>
                        </Grid>

                        <!-- Placeholder -->
                        <Border x:Name="EditorPlaceholder" Background="#0F0F12" BorderBrush="#19191E" BorderThickness="1" Padding="36">
                            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                <TextBlock Text="&#xE739;" FontFamily="Segoe MDL2 Assets" FontSize="56" Foreground="#1C1C22" HorizontalAlignment="Center"/>
                                <TextBlock Text="Soldan bir oyun seçin" Foreground="White" FontSize="26" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,20,0,0"/>
                                <TextBlock x:Name="txtPlaceholderHint" Text="Yayındaki bir oyunu seçtiğinizde düzenleme alanı burada açılır." Foreground="#8F98A5" FontSize="13" Margin="0,12,0,0" HorizontalAlignment="Center" TextAlignment="Center" Width="300" TextWrapping="Wrap"/>
                            </StackPanel>
                        </Border>
                    </Grid>
                </Grid>
            </Grid>
        </Grid>
    </Border>
</Window>

